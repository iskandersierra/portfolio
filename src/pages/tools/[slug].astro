---
import { render } from 'astro:content';
import ToolLayout from '../../layouts/ToolLayout.astro';
import { getAdjacentTools, getPublishedTools, type ToolEntry } from '../../utils/content';

interface Props {
	tool: ToolEntry;
	adjacentTools: ReturnType<typeof getAdjacentTools>;
}

export async function getStaticPaths() {
	const tools = await getPublishedTools();

	return tools.map((tool) => ({
		params: { slug: tool.id },
		props: {
			tool,
			adjacentTools: getAdjacentTools(tools, tool.id),
		},
	}));
}

const { tool, adjacentTools } = Astro.props as Props;
const { Content } = await render(tool);
---

<ToolLayout tool={tool} adjacentTools={adjacentTools}>
	<Content />
</ToolLayout>
