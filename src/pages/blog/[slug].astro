---
import { render } from 'astro:content';
import BlogPostLayout from '../../layouts/BlogPostLayout.astro';
import {
	getAdjacentBlogPosts,
	getPublishedBlogPosts,
	type BlogEntry,
} from '../../utils/content';

interface Props {
	post: BlogEntry;
	adjacentPosts: ReturnType<typeof getAdjacentBlogPosts>;
}

export async function getStaticPaths() {
	const posts = await getPublishedBlogPosts();

	return posts.map((post) => ({
		params: { slug: post.id },
		props: {
			post,
			adjacentPosts: getAdjacentBlogPosts(posts, post.id),
		},
	}));
}

const { post, adjacentPosts } = Astro.props as Props;
const { Content } = await render(post);
---

<BlogPostLayout post={post} adjacentPosts={adjacentPosts}>
	<Content />
</BlogPostLayout>
