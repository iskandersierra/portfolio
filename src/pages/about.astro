---
import Layout from '../layouts/Layout.astro';

const expertise = [
	{
		signal: 'N01',
		label: '.NET architecture',
		detail: 'Feature-driven services, dependable boundaries, and systems that stay understandable as they grow.',
	},
	{
		signal: 'N02',
		label: 'Team technical leadership',
		detail: 'Leading through clarity, design reviews, and delivery habits that raise the technical floor for the team.',
	},
	{
		signal: 'N03',
		label: 'TypeScript and JavaScript',
		detail: 'Building interfaces and tooling that feel considered, not assembled, while keeping performance and semantics intact.',
	},
	{
		signal: 'N04',
		label: 'Azure and cloud delivery',
		detail: 'Shipping cloud systems with operational discipline, practical observability, and steady release flow.',
	},
	{
		signal: 'N05',
		label: 'Docker and Kubernetes',
		detail: 'Containerized development and deployment patterns that support repeatable environments and calm operations.',
	},
	{
		signal: 'N06',
		label: 'Computer science fundamentals',
		detail: 'The foundations that keep architecture, debugging, and tradeoff decisions grounded in first principles.',
	},
];

const profileModules = [
	{
		title: 'System role',
		copy: 'Full-stack developer, software architect, and technical lead working across product delivery and engineering quality.',
	},
	{
		title: 'Operating mode',
		copy: 'I do my best work where architecture and implementation stay connected, so strategy still cashes out as working software.',
	},
	{
		title: 'What this site does',
		copy: 'It makes long-term learning visible through real posts, tools, and design decisions instead of a static list of claims.',
	},
];

const experienceTimeline = [
	{
		signal: 'A01',
		span: '25 years in software',
		title: 'Engineering depth before abstraction',
		copy:
			'The foundation is still hands-on software delivery: building features, debugging real systems, and learning which fundamentals keep paying off as stacks change.',
		points: ['application delivery', 'debugging discipline', 'computer science fundamentals'],
	},
	{
		signal: 'A02',
		span: 'architecture + delivery leadership',
		title: 'Systems thinking at product scale',
		copy:
			'That experience grew into architecture work, technical direction, and release planning where reliability, maintainability, and team clarity matter as much as raw implementation speed.',
		points: ['architecture decisions', 'technical leadership', 'delivery flow'],
	},
	{
		signal: 'A03',
		span: 'current operating mode',
		title: 'Learning in public through shipped work',
		copy:
			'The current arc connects writing, tools, and design experiments so the portfolio shows how ideas move from principles to implementation instead of living as disconnected claims.',
		points: ['writing', 'tooling', 'continuous learning'],
	},
];

const educationModules = [
	{
		signal: 'E01',
		title: 'Computer science background',
		copy:
			'A computer science foundation still anchors the way I reason about architecture, debugging, tradeoffs, and long-term maintainability.',
	},
	{
		signal: 'E02',
		title: 'Working philosophy',
		copy:
			'I prefer systems where architecture remains close to implementation, teams can explain why the design exists, and learning keeps improving the work instead of staying theoretical.',
	},
];

const profileLinks = [
	{
		signal: 'L01',
		label: 'GitHub',
		href: 'https://github.com/iskandersierra',
		copy: 'Code, experiments, and the public trail of shipped work.',
	},
	{
		signal: 'L02',
		label: 'LinkedIn',
		href: 'https://www.linkedin.com/in/iskandersierra/',
		copy: 'Professional profile, background context, and direct contact path.',
	},
];

const profileSchema = JSON.stringify({
	'@context': 'https://schema.org',
	'@type': 'Person',
	'@id': 'https://isksz.com/about/#person',
	name: 'Iskander Sierra',
	url: 'https://isksz.com/about/',
	description:
		'Senior full-stack developer, software architect, and technical lead with 25 years of experience building software, leading delivery, and documenting continuous learning.',
		jobTitle: 'Full-Stack Developer, Software Architect, and Technical Lead',
		sameAs: profileLinks.map((link) => link.href),
		knowsAbout: expertise.map((item) => item.label),
	});

const profileRoles = [
	{ label: 'architect' },
	{ label: 'developer' },
	{ label: 'technical lead' },
	{ label: 'continuous learner' },
];
---

<Layout
	seo={{
		title: 'About',
		description:
			'Learn more about Iskander Sierra, a senior full-stack developer, architect, and technical lead with 25 years of experience building software and teams.',
		pageType: 'website',
	}}
>
	<script is:inline type="application/ld+json" set:html={profileSchema}></script>
	<main class="container page-shell about-surface">
		<header class="about-hero motion-enter motion-delay-1">
			<div class="about-hero__copy">
				<p class="mono page-kicker">profile graph / capability map</p>
				<h1>About</h1>
				<p class="page-intro">
					I am a full-stack developer, software architect, and team technical lead focused on
					building dependable systems, helping teams move with clarity, and staying curious enough
					to keep learning.
				</p>
				<dl class="about-stats" aria-label="About page summary">
					<div>
						<dt class="mono">experience arc</dt>
						<dd>25 years</dd>
					</div>
					<div>
						<dt class="mono">active roles</dt>
						<dd>{profileRoles.length}</dd>
					</div>
					<div>
						<dt class="mono">core nodes</dt>
						<dd>{expertise.length}</dd>
					</div>
				</dl>
			</div>

			<aside class="profile-map" aria-labelledby="profile-map-title">
				<div class="profile-map__header">
					<p class="mono profile-map__eyebrow" id="profile-map-title">Connected profile modules</p>
					<p class="mono profile-map__status">identity://resolved</p>
				</div>
				<ul class="profile-map__legend" aria-label="Profile role labels">
					{profileRoles.map((role) => (
						<li class="profile-map__legend-item">
							<span class="profile-map__legend-label">{role.label}</span>
						</li>
					))}
				</ul>
			</aside>
		</header>

		<div class="about-grid motion-enter motion-delay-2">
			<section class="section-block expertise-network" aria-labelledby="expertise-network-title">
				<div class="section-heading">
					<p class="mono section-kicker">capability nodes</p>
					<h2 id="expertise-network-title">Expertise that travels together</h2>
					<p>
						These are not isolated tags. They reinforce each other in real delivery work, which is
						why they are presented as linked nodes instead of a flat skill dump.
					</p>
				</div>
				<div class="expertise-grid">
					{expertise.map((item) => (
						<article class="expertise-node">
							<h3>{item.label}</h3>
							<p>{item.detail}</p>
						</article>
					))}
				</div>
			</section>

			<aside class="about-sidebar" aria-label="Profile context modules">
				<section class="section-block timeline-panel" aria-labelledby="experience-timeline-title">
					<div class="section-heading section-heading--compact">
						<p class="mono section-kicker">experience arc</p>
						<h2 id="experience-timeline-title">How the profile evolved</h2>
						<p>
							A scannable arc instead of a resume dump: the through-line is hands-on delivery,
							architecture thinking, and the habit of keeping learning visible.
						</p>
					</div>
					<ol class="timeline-list">
						{experienceTimeline.map((entry) => (
							<li class="timeline-entry">
								<div class="timeline-entry__rail" aria-hidden="true">
									<span class="timeline-entry__line"></span>
								</div>
								<div class="timeline-entry__body">
									<p class="mono timeline-entry__span">{entry.span}</p>
									<h3>{entry.title}</h3>
									<p>{entry.copy}</p>
									<ul class="timeline-entry__points" aria-label={`${entry.title} focus points`}>
										{entry.points.map((point) => (
											<li>{point}</li>
										))}
									</ul>
								</div>
							</li>
						))}
					</ol>
				</section>

				<section class="section-block profile-modules">
					<div class="section-heading section-heading--compact">
						<p class="mono section-kicker">profile modules</p>
						<h2>How I work</h2>
					</div>
					<div class="profile-module-list">
						{profileModules.map((module) => (
							<article class="profile-module-card">
								<h3>{module.title}</h3>
								<p>{module.copy}</p>
							</article>
						))}
					</div>
				</section>

				<section class="section-block education-panel" aria-labelledby="education-panel-title">
					<div class="section-heading section-heading--compact">
						<p class="mono section-kicker">education + philosophy</p>
						<h2 id="education-panel-title">Grounding layers</h2>
					</div>
					<div class="education-grid">
						{educationModules.map((module) => (
							<article class="education-card">
								<h3>{module.title}</h3>
								<p>{module.copy}</p>
							</article>
						))}
					</div>
				</section>

				<section class="section-block links-panel" aria-labelledby="links-panel-title">
					<div class="section-heading section-heading--compact">
						<p class="mono section-kicker">external routes</p>
						<h2 id="links-panel-title">Profile links and CV status</h2>
					</div>
					<div class="profile-link-grid">
						{profileLinks.map((link) => (
							<a class="profile-link-card" href={link.href} target="_blank" rel="noreferrer">
								<div>
									<h3>{link.label}</h3>
									<p>{link.copy}</p>
								</div>
								<span class="mono profile-link-card__cta">open profile →</span>
							</a>
						))}
						<article class="cv-status-card" aria-label="CV download status">
							<h3>CV download</h3>
							<p>
								No placeholder PDF ships here. The public CV download stays deferred until there is a
								real document ready to publish.
							</p>
							<p class="mono cv-status-card__state">status / explicitly deferred</p>
						</article>
					</div>
				</section>

				<section class="section-block profile-note motion-enter motion-delay-3">
					<div class="section-heading section-heading--compact">
						<p class="mono section-kicker">system note</p>
						<h2>Why this page exists</h2>
					</div>
					<p>
						This site sits at the intersection of architecture, delivery, and continuous learning.
						It is a place to share practical experience, document new ideas, and make long-term
						growth visible through real work.
					</p>
				</section>
			</aside>
		</div>
	</main>
</Layout>

<style>
	.about-surface {
		padding-block: 2rem 4rem;
	}

	.about-hero,
	.section-block {
		position: relative;
		border: 1px solid color-mix(in srgb, var(--border-strong) 72%, transparent);
		background:
			linear-gradient(180deg, color-mix(in srgb, var(--surface-strong) 92%, transparent) 0%, color-mix(in srgb, var(--surface) 94%, transparent) 100%);
		box-shadow: var(--panel-shadow-soft);
		overflow: clip;
	}

	.about-hero::before,
	.section-block::before {
		content: '';
		position: absolute;
		inset: 0;
		pointer-events: none;
		background:
			linear-gradient(var(--grid-line) 1px, transparent 1px),
			linear-gradient(90deg, var(--grid-line) 1px, transparent 1px);
		background-size: 3rem 3rem;
		opacity: 0.45;
		mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.62), transparent 86%);
	}

	.about-hero {
		display: grid;
		grid-template-columns: minmax(0, 1.18fr) minmax(18rem, 0.92fr);
		gap: 1.25rem;
		padding: clamp(1.1rem, 2.8vw, 1.7rem);
		margin-bottom: 1.25rem;
	}

	.page-kicker,
	.section-kicker,
	.profile-map__eyebrow,
	.profile-map__status,
	.about-stats dt {
		margin: 0;
		font-size: 0.72rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	.page-kicker,
	.section-kicker,
	.profile-map__eyebrow {
		color: var(--accent-2);
	}

	.profile-map__status,
	.about-stats dt {
		color: var(--text-soft);
	}

	.about-hero h1 {
		margin: 0.55rem 0 0.9rem;
		font-size: clamp(2.8rem, 5.4vw, 4.6rem);
		line-height: 0.96;
	}

	.page-intro,
	.section-heading p,
	.expertise-node p,
	.profile-module-card p,
	.profile-note p {
		max-width: 64ch;
		line-height: 1.7;
		color: var(--text-muted);
	}

	.about-stats {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0.75rem;
		margin: 1.5rem 0 0;
	}

	.about-stats div {
		padding: 0.95rem 1rem;
		border: 1px solid var(--border);
		background: color-mix(in srgb, var(--surface-soft) 84%, transparent);
}

	.about-stats dd {
		margin: 0.4rem 0 0;
		font-size: 1rem;
		font-weight: 700;
		color: var(--text-main);
	}

	.profile-map {
		display: grid;
		gap: 1rem;
	}

	.profile-map__header,
	.section-heading {
		display: grid;
		gap: 0.35rem;
	}

	.profile-map__legend {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.65rem;
	}

	.profile-map__legend-item {
		display: block;
		padding: 0.75rem 0.8rem;
		border: 1px solid var(--border);
		background: color-mix(in srgb, var(--surface-soft) 78%, transparent);
	}

	.profile-map__legend-label {
		color: var(--text-main);
		text-transform: lowercase;
		font-weight: 600;
	}

	.about-grid {
		display: grid;
		grid-template-columns: minmax(0, 1.2fr) minmax(18rem, 0.8fr);
		gap: 1.25rem;
	}

	.section-block {
		padding: clamp(1.1rem, 2.6vw, 1.5rem);
	}

	.section-heading h2,
	.expertise-node h3,
	.profile-module-card h3,
	.timeline-entry__body h3,
	.education-card h3,
	.profile-link-card h3,
	.cv-status-card h3 {
		margin: 0;
	}

	.section-heading h2 {
		font-size: clamp(1.45rem, 2.5vw, 2rem);
	}

	.about-sidebar,
	.profile-module-list,
	.expertise-grid,
	.education-grid,
	.profile-link-grid,
	.timeline-list {
		display: grid;
		gap: 1rem;
	}

	.expertise-grid {
		grid-template-columns: repeat(2, minmax(0, 1fr));
		counter-reset: expertise-counter;
	}

	.expertise-node,
	.profile-module-card,
	.timeline-entry,
	.education-card,
	.profile-link-card,
	.cv-status-card {
		position: relative;
		padding: 1rem;
		border: 1px solid var(--border);
		background: color-mix(in srgb, var(--surface-soft) 78%, transparent);
		transition: border-color 0.2s ease, background-color 0.2s ease, box-shadow 0.2s ease;
	}

	.expertise-node {
		border-left: 2px solid color-mix(in srgb, var(--accent-3) 56%, var(--border));
		counter-increment: expertise-counter;
	}

	.expertise-node:hover {
		border-color: var(--accent);
		border-left-color: var(--accent);
		background: color-mix(in srgb, var(--accent) 7%, var(--surface-soft));
		box-shadow: 0 0 18px color-mix(in srgb, var(--accent) 12%, transparent);
	}

	.expertise-node::before {
		content: counter(expertise-counter, decimal-leading-zero);
		position: absolute;
		top: 0.6rem;
		right: 0.7rem;
		font-family: 'Azeret Mono', monospace;
		font-size: 0.62rem;
		letter-spacing: 0.1em;
		color: var(--text-soft);
		opacity: 0.7;
	}

	.expertise-node h3,
	.profile-module-card h3,
	.timeline-entry__body h3,
	.education-card h3,
	.profile-link-card h3,
	.cv-status-card h3 {
		font-size: 1.1rem;
	}

	.expertise-node::after,
	.profile-module-card::after,
	.education-card::after,
	.cv-status-card::after {
		content: '';
		position: absolute;
		inset: auto auto 0.7rem 1rem;
		width: 3rem;
		height: 1px;
		background: linear-gradient(90deg, var(--accent-2), transparent);
	}

	.timeline-list {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.timeline-entry {
		display: grid;
		grid-template-columns: auto minmax(0, 1fr);
		gap: 0.9rem;
		padding-bottom: 1.1rem;
	}

	.timeline-entry__rail {
		display: grid;
		justify-items: center;
		min-width: 1rem;
		padding-top: 0.15rem;
	}

	.timeline-entry__rail::before {
		content: '';
		display: block;
		width: 9px;
		height: 9px;
		border-radius: 999px;
		border: 1px solid color-mix(in srgb, var(--accent-2) 70%, var(--border));
		background: radial-gradient(circle, color-mix(in srgb, var(--node-core) 90%, white) 0 36%, transparent 37%);
		box-shadow: 0 0 7px color-mix(in srgb, var(--accent-2) 30%, transparent);
		margin-bottom: 0.3rem;
		flex-shrink: 0;
	}

	.profile-note p,
	ul.timeline-entry__points li {
		font-size: 0.72rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	.timeline-entry__span,
	.cv-status-card__state,
	.profile-link-card__cta,
	.timeline-entry__points li {
		font-size: 0.72rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	.profile-note {
		border-left: 3px solid var(--accent);
	}

	.timeline-entry__line {
		width: 1px;
		min-height: 100%;
		background: linear-gradient(180deg, color-mix(in srgb, var(--accent) 78%, transparent), transparent 88%);
	}

	.timeline-entry__body {
		display: grid;
		gap: 0.7rem;
	}

	.timeline-entry__span,
	.cv-status-card__state,
	.profile-link-card__cta {
		color: var(--text-soft);
	}

	.timeline-entry__body p,
	.education-card p,
	.profile-link-card p,
	.cv-status-card p {
		margin: 0;
		line-height: 1.7;
		color: var(--text-muted);
	}

	.timeline-entry__points {
		display: flex;
		flex-wrap: wrap;
		gap: 0.55rem;
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.timeline-entry__points li {
		padding: 0.4rem 0.55rem;
		border: 1px solid color-mix(in srgb, var(--border-strong) 64%, transparent);
		background: color-mix(in srgb, var(--surface) 64%, transparent);
		color: var(--text-soft);
	}

	.education-grid,
	.profile-link-grid {
		grid-template-columns: repeat(2, minmax(0, 1fr));
	}

	.profile-link-card {
		display: flex;
		justify-content: space-between;
		align-items: flex-end;
		gap: 1rem;
		text-decoration: none;
		color: inherit;
		padding-top: 1.15rem;
	}

	.profile-link-card:hover,
	.profile-link-card:focus-visible {
		border-color: var(--accent);
		background: color-mix(in srgb, var(--accent) 10%, var(--surface-strong));
		text-decoration: none;
	}

	@media (max-width: 980px) {
		.about-hero,
		.about-grid {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 560px) {
		.profile-map__legend {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 720px) {
		.about-hero,
		.section-block {
			padding: 1rem;
		}

		.about-stats,
		expertise-grid,
		education-grid,
		.profile-link-grid {
			grid-template-columns: 1fr;
		}

		.timeline-entry {
			grid-template-columns: 1fr;
		}

		.timeline-entry__rail {
			grid-auto-flow: column;
			justify-content: start;
		}

		.timeline-entry__line {
			width: 2.8rem;
			min-height: 1px;
			margin-top: 0.45rem;
			background: linear-gradient(90deg, color-mix(in srgb, var(--accent) 78%, transparent), transparent 88%);
		}

		.profile-link-card {
			flex-direction: column;
			align-items: flex-start;
		}
	}

	@media (max-width: 420px) {
		.profile-map__legend-item {
			padding-inline: 0.7rem;
		}
	}
</style>
