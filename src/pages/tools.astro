---
import Layout from '../layouts/Layout.astro';
import { formatContentDate, getPublishedTools, getToolHref } from '../utils/content';

const tools = await getPublishedTools();
---

<Layout
	seo={{
		title: 'Tools',
		description:
			'Browse developer tools and experiments from Iskander Sierra, starting with practical browser-based utilities built as Astro pages and islands.',
		pageType: 'website',
	}}
>
	<main class="container page-shell">
		<header class="page-header motion-enter motion-delay-1">
			<p class="mono page-kicker">$ ls ./tools</p>
			<h1>Tools</h1>
			<p class="page-intro">
				A growing catalog of practical utilities and experiments, built to be useful first and a
				good excuse to explore frameworks, patterns, and interface ideas second.
			</p>
		</header>

		<section class="tool-list motion-enter motion-delay-2">
			{tools.map((tool, index) => (
				<article class="tool-card motion-enter motion-hover-lift" style={`--motion-delay: ${(index + 2) * 80}ms`}>
					<a class="tool-card-link" href={getToolHref(tool.id)} aria-label={`Open ${tool.data.title}`}>
						<div class="tool-head">
							<h2>{tool.data.title}</h2>
							<span class="framework-badge mono">{tool.data.framework}</span>
						</div>
						<p>{tool.data.description}</p>
						<ul class="tag-list">
							{tool.data.tags.map((tag) => <li>{tag}</li>)}
						</ul>
						<p class="tool-meta mono">Published {formatContentDate(tool.data.publishedAt)}</p>
					</a>
				</article>
			))}
		</section>
	</main>
</Layout>

<style>
	.page-shell {
		padding-block: 2rem 4rem;
	}

	.page-header {
		margin-bottom: 2.5rem;
	}

	.page-kicker {
		color: var(--accent);
	}

	.page-header h1 {
		margin: 0.5rem 0 1rem;
		font-size: clamp(2rem, 4vw, 3rem);
	}

	.page-intro,
	.tool-card p {
		max-width: 720px;
		line-height: 1.7;
		color: var(--text-muted);
	}

	.tool-list {
		display: grid;
		gap: 1rem;
	}

	.tool-card {
		border: 1px solid var(--border);
		background: var(--surface);
	}

	.tool-card-link {
		display: grid;
		gap: 0;
		padding: 1.25rem;
		color: inherit;
		text-decoration: none;
	}

	.tool-card-link:hover,
	.tool-card-link:focus-visible {
		text-decoration: none;
	}

	.tool-card-link:focus-visible {
		outline: 2px solid var(--accent);
		outline-offset: 3px;
	}

	.tool-meta {
		margin: 1rem 0 0;
		color: var(--text-muted);
		font-size: 0.9rem;
	}

	.tool-head {
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		align-items: baseline;
		flex-wrap: wrap;
	}

	.tool-head h2 {
		margin: 0;
	}

	.tool-card-link:hover .tool-head h2,
	.tool-card-link:focus-visible .tool-head h2 {
		color: var(--accent);
	}

	.framework-badge {
		padding: 0.25rem 0.6rem;
		border: 1px solid var(--border);
		color: var(--accent);
		font-size: 0.9rem;
	}

	.tag-list {
		list-style: none;
		padding: 0;
		margin: 1rem 0 0;
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.tag-list li {
		padding: 0.25rem 0.6rem;
		border: 1px solid var(--border);
		color: var(--accent);
		font-size: 0.9rem;
	}
</style>
