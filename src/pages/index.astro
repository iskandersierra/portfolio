---
import Layout from '../layouts/Layout.astro';
import Card from '../components/ui/Card.astro';
import { getFeaturedBlogPost, getFeaturedTool } from '../utils/content';

const [featuredPost, featuredTool] = await Promise.all([getFeaturedBlogPost(), getFeaturedTool()]);
---

<Layout
	seo={{
		description:
			"After 25 years in software, the most valuable thing I've learned is that there's always more to learn. This is my living portfolio, where I share what I know, experiment with new ideas, and document the journey.",
		pageType: 'website',
		socialImageAlt:
			'Preview card for Iskander Sierra\'s portfolio with a terminal-inspired visual treatment.',
	}}
>
	<main class="container page-shell">
		<header class="hero motion-enter motion-delay-1">
			<h1>"Never stop learning."<span class="cursor"></span></h1>
			<p class="hero-text motion-enter motion-delay-2">
				After 25 years in software, the most valuable thing I've learned is that there's always
				more to learn. Welcome to my living portfolio — a place where I share what I know,
				experiment with new ideas, and document the journey.
			</p>
		</header>

		<section class="recent-posts motion-enter motion-delay-3">
			<h2 class="section-title mono">$ ls ./featured-content</h2>
			<div class="cards-grid">
				{featuredPost && (
					<Card
						title={featuredPost.data.title}
						description={featuredPost.data.excerpt}
						href="/blog"
						motionClass="motion-delay-3"
						linkText="open ./blog_index.sh →"
						ariaLabel={`Open the blog section featuring ${featuredPost.data.title}`}
					/>
				)}
				{featuredTool && (
					<Card
						title={featuredTool.data.title}
						description={`${featuredTool.data.framework} · ${featuredTool.data.description}`}
						href="/tools"
						motionClass="motion-delay-4"
						linkText="open ./tools_catalog.sh →"
						ariaLabel={`Open the tools section featuring ${featuredTool.data.title}`}
					/>
				)}
			</div>
		</section>
	</main>
</Layout>

<style>
	.hero {
		margin-top: 2rem;
		margin-bottom: 4rem;
	}

	.hero h1 {
		font-size: clamp(2rem, 5vw, 3.5rem);
		margin-bottom: 1rem;
		color: var(--text-main);
	}

	.hero-text {
		font-size: 1.15rem;
		color: var(--text-muted);
		max-width: 700px;
		line-height: 1.7;
	}

	.section-title {
		color: var(--accent);
		font-size: 1.25rem;
		margin-bottom: 1.5rem;
	}

	.cards-grid {
		display: grid;
		gap: 1rem;
	}
</style>
