---
import Layout from '../layouts/Layout.astro';
import {
	formatContentDate,
	getBlogPostHref,
	getFeaturedBlogPost,
	getFeaturedTool,
	getToolHref,
} from '../utils/content';

const graphNodes = [
{ signal: '01', label: 'Home hub', meta: 'portfolio control layer' },
{ signal: '02', label: 'About modules', meta: 'profile and expertise graph', href: '/about' },
{ signal: '03', label: 'Blog archive', meta: 'architecture and learning signals', href: '/blog' },
{ signal: '04', label: 'Tools registry', meta: 'practical browser modules', href: '/tools' },
];

const [featuredPost, featuredTool] = await Promise.all([getFeaturedBlogPost(), getFeaturedTool()]);
const featuredPostHref = featuredPost ? getBlogPostHref(featuredPost.id) : '/blog';
const featuredToolHref = featuredTool ? getToolHref(featuredTool.id) : '/tools';
const featuredModules = [
	{
		signal: '03',
		eyebrow: 'Writing signal',
		title: featuredPost?.data.title ?? 'Blog archive',
		summary:
			featuredPost?.data.excerpt ??
			'Read the latest notes on software architecture, technical leadership, and long-term learning.',
		href: featuredPostHref,
		pathLabel: featuredPost ? `/blog/${featuredPost.id}` : '/blog',
		status: featuredPost ? 'latest note' : 'archive route',
		meta: featuredPost
			? `${formatContentDate(featuredPost.data.date)} / architecture signal`
			: 'route / blog archive',
		linkText: featuredPost ? 'open writing module →' : 'open writing graph →',
		ariaLabel: featuredPost
			? `Open featured blog post ${featuredPost.data.title}`
			: 'Open the blog section',
	},
	{
		signal: '04',
		eyebrow: 'Tool module',
		title: featuredTool?.data.title ?? 'Tools registry',
		summary: featuredTool
			? `${featuredTool.data.framework} module for ${featuredTool.data.description}`
			: 'Browse practical developer tools and experiments built for the portfolio.',
		href: featuredToolHref,
		pathLabel: featuredTool ? `/tools/${featuredTool.id}` : '/tools',
		status: featuredTool ? 'current release' : 'registry route',
		meta: featuredTool
			? `${featuredTool.data.framework} / published module`
			: 'route / tools registry',
		linkText: featuredTool ? 'open tool module →' : 'open tools registry →',
		ariaLabel: featuredTool
			? `Open featured tool ${featuredTool.data.title}`
			: 'Open the tools section',
	},
];
---

<Layout
seo={{
description:
"After 25 years in software, the most valuable thing I've learned is that there's always more to learn. This is my living portfolio, where I share what I know, experiment with new ideas, and document the journey.",
pageType: 'website',
socialImageAlt:
'Preview card for Iskander Sierra\'s portfolio with a terminal-inspired visual treatment.',
}}
>
<main class="container page-shell home-surface">
<header class="home-hero motion-enter motion-delay-1">
<div class="home-hero__copy">
<p class="mono home-kicker">signal graph / home surface</p>
<h1>"Never stop learning."<span class="cursor"></span></h1>
<p class="home-hero__lead motion-enter motion-delay-2">
After 25 years in software, the most valuable thing I've learned is that there is
always another relationship worth understanding. This portfolio is the active graph of
that work: architecture notes, shipped tools, leadership signals, and the learning loops
that connect them.
</p>
<div class="home-hero__actions">
<a class="home-action home-action--primary mono" href="/about">open profile modules</a>
<a class="home-action mono" href="/blog">trace the writing graph</a>
</div>
<dl class="home-metrics" aria-label="Home page signal metrics">
<div>
<dt class="mono">active focus</dt>
<dd>systems thinking</dd>
</div>
<div>
<dt class="mono">featured nodes</dt>
<dd>02</dd>
</div>
<div>
<dt class="mono">route map</dt>
<dd>home / about / blog / tools</dd>
</div>
</dl>
</div>

<aside class="home-graph" aria-labelledby="home-graph-title">
<div class="home-graph__header">
<p class="mono home-graph__eyebrow" id="home-graph-title">Signal graph preview</p>
<p class="mono home-graph__status">network://live</p>
</div>
<div class="home-graph__field" aria-hidden="true">
<span class="home-graph__orbit home-graph__orbit--a"></span>
<span class="home-graph__orbit home-graph__orbit--b"></span>
<span class="home-graph__wire home-graph__wire--a"></span>
<span class="home-graph__wire home-graph__wire--b"></span>
<span class="home-graph__wire home-graph__wire--c"></span>
{graphNodes.map((node, index) => (
<span class={`home-graph__node home-graph__node--${index + 1}`}>
<span class="mono">{node.signal}</span>
<strong>{node.label}</strong>
<small>{node.meta}</small>
</span>
))}
</div>
<ul class="home-graph__legend" aria-label="Connected route modules">
{graphNodes.map((node) => (
<li>
{node.href ? (
<a href={node.href}>
<span class="mono">{node.signal}</span>
<span>{node.label}</span>
</a>
) : (
<span>
<span class="mono">{node.signal}</span>
<span>{node.label}</span>
</span>
)}
</li>
))}
</ul>
</aside>
</header>

<div class="home-layout motion-enter motion-delay-3">
<section class="recent-posts" aria-labelledby="featured-signals-title">
<div class="section-heading">
<p class="mono section-kicker">featured signal paths</p>
<h2 id="featured-signals-title">Current live nodes</h2>
<p>
The home surface stays data-driven. The newest writing node and the current tool release
stay connected here as adjacent modules instead of falling back to the older shared-card strip.
</p>
</div>
<div class="feature-network" aria-label="Featured content network">
<span class="feature-network__spine" aria-hidden="true"></span>
<span class="feature-network__bridge feature-network__bridge--a" aria-hidden="true"></span>
<span class="feature-network__bridge feature-network__bridge--b" aria-hidden="true"></span>
{featuredModules.map((module, index) => (
<article class={`signal-module motion-enter motion-hover-lift motion-delay-${index + 3}`}>
<div class="signal-module__trace" aria-hidden="true">
<span class="mono signal-module__signal">{module.signal}</span>
<span class="signal-module__trace-line"></span>
</div>
<div class="signal-module__body">
<p class="mono signal-module__eyebrow">{module.eyebrow}</p>
<div class="signal-module__head">
<div>
<h3>{module.title}</h3>
<p class="mono signal-module__path">{module.pathLabel}</p>
</div>
<span class="mono signal-module__status">{module.status}</span>
</div>
<p>{module.summary}</p>
<dl class="signal-module__meta" aria-label={`${module.title} metadata`}>
<div>
<dt class="mono">signal meta</dt>
<dd>{module.meta}</dd>
</div>
</dl>
</div>
<a href={module.href} class="signal-module__link mono" aria-label={module.ariaLabel}>
{module.linkText}
</a>
</article>
))}
</div>
</section>

<aside class="home-sidebar" aria-label="Home context modules">
<section class="home-module">
<div class="section-heading section-heading--compact">
<p class="mono section-kicker">connected practice</p>
<h2>Why this reads like a graph</h2>
</div>
<p>
The work is organized around relationships: architecture informs delivery, leadership
shapes systems, and experiments feed the next tool or article instead of disappearing.
</p>
</section>

<section class="home-module home-module--list">
<div class="section-heading section-heading--compact">
<p class="mono section-kicker">profile routes</p>
<h2>Open next modules</h2>
</div>
<ul class="module-links">
<li>
<a href="/about">
<span class="mono">02</span>
<strong>About</strong>
<small>Profile, expertise, and operating mode.</small>
</a>
</li>
<li>
<a href="/blog">
<span class="mono">03</span>
<strong>Blog</strong>
<small>Architecture, leadership, and learning signals.</small>
</a>
</li>
<li>
<a href="/tools">
<span class="mono">04</span>
<strong>Tools</strong>
<small>Practical modules built in the browser.</small>
</a>
</li>
</ul>
</section>
</aside>
</div>
</main>
</Layout>

<style>
.home-surface {
padding-block: 2rem 4rem;
}

.home-hero,
.recent-posts,
.home-module {
position: relative;
border: 1px solid color-mix(in srgb, var(--border-strong) 72%, transparent);
background:
linear-gradient(180deg, color-mix(in srgb, var(--surface-strong) 92%, transparent) 0%, color-mix(in srgb, var(--surface) 94%, transparent) 100%);
box-shadow: var(--panel-shadow-soft);
overflow: clip;
}

.home-hero::before,
.recent-posts::before,
.home-module::before {
content: '';
position: absolute;
inset: 0;
pointer-events: none;
background:
linear-gradient(var(--grid-line) 1px, transparent 1px),
linear-gradient(90deg, var(--grid-line) 1px, transparent 1px);
background-size: 3rem 3rem;
opacity: 0.45;
mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.62), transparent 86%);
}

.home-hero {
display: grid;
grid-template-columns: minmax(0, 1.22fr) minmax(19rem, 0.9fr);
gap: 1.25rem;
padding: clamp(1.1rem, 2.8vw, 1.7rem);
margin-bottom: 1.25rem;
}

.home-kicker,
.section-kicker,
.home-graph__eyebrow,
.home-graph__status,
.home-metrics dt {
margin: 0;
font-size: 0.72rem;
letter-spacing: 0.12em;
text-transform: uppercase;
}

.home-kicker,
.section-kicker,
.home-graph__eyebrow {
color: var(--accent-2);
}

.home-graph__status,
.home-metrics dt {
color: var(--text-soft);
}

.home-hero h1 {
margin: 0.6rem 0 0.9rem;
font-size: clamp(3rem, 6vw, 5.4rem);
line-height: 0.96;
max-width: 8ch;
}

.home-hero__lead,
.section-heading p,
.home-module p {
font-size: 1.05rem;
color: var(--text-muted);
line-height: 1.7;
max-width: 62ch;
}

.home-hero__actions {
display: flex;
flex-wrap: wrap;
gap: 0.75rem;
margin-top: 1.35rem;
}

.home-action {
display: inline-flex;
align-items: center;
justify-content: center;
min-height: 2.8rem;
padding: 0.7rem 1rem;
border: 1px solid color-mix(in srgb, var(--border-strong) 68%, transparent);
border-radius: 999px;
background: color-mix(in srgb, var(--surface-soft) 78%, transparent);
color: var(--text-main);
letter-spacing: 0.08em;
text-transform: uppercase;
}

.home-action:hover,
.home-action:focus-visible,
.home-action--primary {
border-color: var(--accent);
background: color-mix(in srgb, var(--accent) 12%, var(--surface-strong));
text-decoration: none;
}

.home-metrics {
display: grid;
grid-template-columns: repeat(3, minmax(0, 1fr));
gap: 0.75rem;
margin: 1.5rem 0 0;
}

.home-metrics div {
padding: 0.95rem 1rem;
border: 1px solid var(--border);
background: color-mix(in srgb, var(--surface-soft) 84%, transparent);
}

.home-metrics dd {
margin: 0.4rem 0 0;
font-size: 1rem;
font-weight: 700;
color: var(--text-main);
}

.home-graph {
display: grid;
gap: 1rem;
}

.home-graph__header,
.section-heading {
display: grid;
gap: 0.35rem;
}

.section-heading h2,
.home-module h2 {
margin: 0;
font-size: clamp(1.45rem, 2.5vw, 2rem);
}

.section-heading--compact h2,
.home-module h2 {
font-size: 1.2rem;
}

.home-graph__field {
position: relative;
min-height: 18rem;
border: 1px solid color-mix(in srgb, var(--border-strong) 60%, transparent);
background:
radial-gradient(circle at 18% 18%, color-mix(in srgb, var(--accent) 16%, transparent) 0, transparent 28%),
radial-gradient(circle at 80% 16%, color-mix(in srgb, var(--accent-2) 12%, transparent) 0, transparent 24%),
color-mix(in srgb, var(--surface-soft) 78%, transparent);
overflow: hidden;
}

.home-graph__orbit,
.home-graph__wire,
.home-graph__node {
position: absolute;
display: block;
}

.home-graph__orbit {
border: 1px solid color-mix(in srgb, var(--border-strong) 52%, transparent);
border-radius: 999px;
opacity: 0.4;
}

.home-graph__orbit--a {
left: 1rem;
top: 1rem;
width: 12rem;
height: 12rem;
}

.home-graph__orbit--b {
right: 1.4rem;
bottom: 1rem;
width: 8rem;
height: 8rem;
}

.home-graph__wire {
height: 1px;
background: linear-gradient(90deg, transparent, var(--line-strong), transparent);
transform-origin: left center;
}

.home-graph__wire--a {
top: 3.4rem;
left: 5rem;
width: 11rem;
transform: rotate(9deg);
}

.home-graph__wire--b {
top: 8.2rem;
right: 4rem;
width: 9rem;
transform: rotate(138deg);
}

.home-graph__wire--c {
left: 7rem;
bottom: 4rem;
width: 12rem;
transform: rotate(-7deg);
}

.home-graph__node {
padding: 0.6rem 0.7rem;
border: 1px solid color-mix(in srgb, var(--border-strong) 66%, transparent);
background: color-mix(in srgb, var(--surface-strong) 90%, transparent);
box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--frame-glow) 92%, transparent);
}

.home-graph__node span,
.home-graph__legend .mono {
font-size: 0.62rem;
letter-spacing: 0.12em;
text-transform: uppercase;
color: var(--accent-2);
}

.home-graph__node strong,
.home-graph__legend strong {
display: block;
margin-top: 0.3rem;
color: var(--text-main);
font-size: 0.95rem;
}

.home-graph__node small {
display: block;
margin-top: 0.2rem;
color: var(--text-muted);
font-size: 0.75rem;
}

.home-graph__node--1 {
top: 1.35rem;
left: 1rem;
}

.home-graph__node--2 {
top: 4rem;
right: 1rem;
}

.home-graph__node--3 {
left: 4.8rem;
bottom: 3.7rem;
}

.home-graph__node--4 {
right: 2.8rem;
bottom: 1rem;
}

.home-graph__legend {
list-style: none;
padding: 0;
margin: 0;
display: grid;
grid-template-columns: repeat(2, minmax(0, 1fr));
gap: 0.6rem;
}

.home-graph__legend li a,
.home-graph__legend li > span {
display: grid;
gap: 0.1rem;
padding: 0.7rem 0.8rem;
border: 1px solid var(--border);
background: color-mix(in srgb, var(--surface-soft) 72%, transparent);
color: var(--text-main);
}

.home-graph__legend li a:hover,
.home-graph__legend li a:focus-visible {
border-color: var(--accent);
background: color-mix(in srgb, var(--accent) 12%, var(--surface-strong));
text-decoration: none;
}

.home-layout {
display: grid;
grid-template-columns: minmax(0, 1.2fr) minmax(18rem, 0.78fr);
gap: 1.25rem;
}

.recent-posts,
.home-module {
padding: clamp(1.1rem, 2.6vw, 1.5rem);
}

.home-sidebar {
display: grid;
gap: 1rem;
align-content: start;
}

.feature-network,
.module-links {
display: grid;
gap: 1rem;
}

.feature-network {
position: relative;
padding-left: clamp(0.6rem, 2vw, 1rem);
}

.feature-network__spine,
.feature-network__bridge {
position: absolute;
display: block;
pointer-events: none;
background: linear-gradient(180deg, transparent, var(--line-strong), transparent);
}

.feature-network__spine {
left: 0;
top: 1rem;
bottom: 1rem;
width: 1px;
}

.feature-network__bridge {
left: 0;
width: clamp(1.25rem, 3vw, 2rem);
height: 1px;
background: linear-gradient(90deg, var(--line-strong), transparent);
}

.feature-network__bridge--a {
top: 4.4rem;
}

.feature-network__bridge--b {
top: calc(50% + 2rem);
}

.signal-module {
display: grid;
grid-template-columns: auto minmax(0, 1fr);
gap: 1rem;
align-items: start;
padding: clamp(1rem, 2.6vw, 1.25rem);
border: 1px solid color-mix(in srgb, var(--border-strong) 72%, transparent);
background:
linear-gradient(180deg, color-mix(in srgb, var(--surface-strong) 92%, transparent) 0%, color-mix(in srgb, var(--surface-soft) 92%, transparent) 100%);
box-shadow: var(--panel-shadow-soft);
position: relative;
overflow: clip;
}

.signal-module::before {
content: '';
position: absolute;
inset: 0;
pointer-events: none;
background:
linear-gradient(var(--grid-line) 1px, transparent 1px),
linear-gradient(90deg, var(--grid-line) 1px, transparent 1px);
background-size: 3rem 3rem;
opacity: 0.38;
mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.62), transparent 86%);
}

.signal-module > * {
position: relative;
z-index: 1;
}

.signal-module__trace {
display: grid;
justify-items: center;
gap: 0.45rem;
min-width: 2.25rem;
padding-top: 0.1rem;
}

.signal-module__signal,
.signal-module__eyebrow,
.signal-module__status,
.signal-module__path,
.signal-module__meta dt {
font-size: 0.68rem;
letter-spacing: 0.12em;
text-transform: uppercase;
}

.signal-module__signal,
.signal-module__eyebrow {
color: var(--accent-2);
}

.signal-module__trace-line {
width: 1px;
min-height: 100%;
flex: 1;
background: linear-gradient(180deg, color-mix(in srgb, var(--accent) 78%, transparent), transparent 88%);
}

.signal-module__body {
display: grid;
gap: 0.75rem;
}

.signal-module__head {
display: flex;
justify-content: space-between;
align-items: flex-start;
gap: 1rem;
flex-wrap: wrap;
}

.signal-module__head h3 {
margin: 0.15rem 0 0;
font-size: clamp(1.3rem, 2.5vw, 1.7rem);
line-height: 1.08;
}

.signal-module__path,
.signal-module__status,
.signal-module__meta dt {
color: var(--text-soft);
}

.signal-module__path {
margin: 0.4rem 0 0;
}

.signal-module__status {
display: inline-flex;
align-items: center;
padding: 0.45rem 0.65rem;
border: 1px solid color-mix(in srgb, var(--border-strong) 68%, transparent);
background: color-mix(in srgb, var(--surface) 60%, transparent);
}

.signal-module__body > p,
.signal-module__meta dd {
margin: 0;
color: var(--text-muted);
line-height: 1.72;
}

.signal-module__meta {
margin: 0;
}

.signal-module__meta div {
display: grid;
gap: 0.3rem;
padding-top: 0.75rem;
border-top: 1px solid color-mix(in srgb, var(--border) 90%, transparent);
}

.signal-module__link {
display: inline-flex;
align-items: center;
justify-content: center;
width: fit-content;
min-height: 2.6rem;
margin-left: calc(2.25rem + 1rem);
padding: 0.45rem 0.8rem;
border: 1px solid color-mix(in srgb, var(--border-strong) 70%, transparent);
background: color-mix(in srgb, var(--surface) 58%, transparent);
color: var(--accent);
letter-spacing: 0.08em;
text-transform: uppercase;
}

.signal-module__link:hover,
.signal-module__link:focus-visible {
border-color: var(--accent);
background: color-mix(in srgb, var(--accent) 12%, var(--surface-strong));
text-decoration: none;
}

.module-links {
list-style: none;
padding: 0;
margin: 0;
}

.module-links a {
display: grid;
gap: 0.15rem;
padding: 0.8rem 0.9rem;
border: 1px solid var(--border);
background: color-mix(in srgb, var(--surface-soft) 72%, transparent);
color: var(--text-main);
}

.module-links a small {
color: var(--text-muted);
font-size: 0.78rem;
}

.module-links a:hover,
.module-links a:focus-visible {
border-color: var(--accent);
background: color-mix(in srgb, var(--accent) 12%, var(--surface-strong));
text-decoration: none;
}

@media (max-width: 980px) {
.home-hero,
.home-layout {
grid-template-columns: 1fr;
}

.home-graph__field {
min-height: 15rem;
}
}

@media (max-width: 720px) {
.home-hero,
.recent-posts,
.home-module {
padding: 1rem;
}

.feature-network {
padding-left: 0;
}

.feature-network__spine,
.feature-network__bridge {
display: none;
}

.signal-module {
grid-template-columns: 1fr;
gap: 0.85rem;
}

.signal-module__trace {
grid-auto-flow: column;
justify-content: start;
min-width: 0;
}

.signal-module__trace-line {
width: 2.8rem;
min-height: 1px;
margin-top: 0.45rem;
background: linear-gradient(90deg, color-mix(in srgb, var(--accent) 78%, transparent), transparent 88%);
}

.signal-module__link {
margin-left: 0;
}

.home-metrics,
.home-graph__legend {
grid-template-columns: 1fr;
}

.home-hero h1 {
font-size: clamp(2.6rem, 13vw, 4rem);
}

.home-graph__field {
min-height: 12rem;
}

.home-graph__node {
padding: 0.45rem 0.55rem;
}

.home-graph__node strong {
font-size: 0.84rem;
}
}
</style>
