---
import Layout from '../layouts/Layout.astro';
import Header from '../components/layout/Header.astro';
import Card from '../components/ui/Card.astro';
---

<Layout>
	<div class="terminal-window">
		<Header />

		<main class="container">
			<header class="hero boot-seq delay-1">
				<h1>"Never stop learning."<span class="cursor"></span></h1>
				<p class="hero-text boot-seq delay-2">
					After 25 years in software, the most valuable thing I've learned is that there's always
					more to learn. Welcome to my living portfolio — a place where I share what I know,
					experiment with new ideas, and document the journey.
				</p>
			</header>

			<section class="recent-posts boot-seq delay-3">
				<h2 class="section-title mono">$ ls ./recent-posts</h2>
				<div class="cards-grid">
					<Card
						title="Clean Architecture in .NET"
						description="Thoughts on structuring large scale enterprise applications with modern C# and CQRS."
						href="/blog"
						delayClass="delay-3"
					/>
					<Card
						title="The value of CS fundamentals"
						description="Why algorithms and data structures still matter 25 years later in modern development."
						href="#"
						delayClass="delay-4"
					/>
				</div>
			</section>
		</main>
	</div>
</Layout>

<style>
	.hero {
		margin-top: 2rem;
		margin-bottom: 4rem;
	}

	.hero h1 {
		font-size: clamp(2rem, 5vw, 3.5rem);
		margin-bottom: 1rem;
		color: var(--text-main);
	}

	.hero-text {
		font-size: 1.15rem;
		color: var(--text-muted);
		max-width: 700px;
		line-height: 1.7;
	}

	.section-title {
		color: var(--accent);
		font-size: 1.25rem;
		margin-bottom: 1.5rem;
	}

	.cards-grid {
		display: grid;
		gap: 1rem;
	}
</style>
