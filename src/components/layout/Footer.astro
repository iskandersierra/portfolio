---
const quickLinks = [
	{ path: '/', label: 'Home', signal: '01' },
	{ path: '/about', label: 'About', signal: '02' },
	{ path: '/blog', label: 'Blog', signal: '03' },
	{ path: '/tools', label: 'Tools', signal: '04' },
];

const socialLinks = [
	{ href: 'https://github.com/iskandersierra', label: 'GitHub', signal: 'A1' },
	{ href: 'https://www.linkedin.com/in/iskandersierra/', label: 'LinkedIn', signal: 'A2' },
];

const isActivePath = (itemPath: string, currentPath: string) =>
	itemPath === '/'
		? currentPath === '/'
		: currentPath === itemPath || currentPath.startsWith(`${itemPath}/`);
---

<footer class="terminal-footer">
	<div class="footer-meta">
		<p class="footer-kicker mono">signal graph</p>
		<p class="footer-title">~/iskander</p>
		<p class="footer-copy">Built for learning, shipping, and sharing practical engineering work.</p>
		<p class="footer-meta-note mono">shared shell / connected practice / adaptive themes</p>
	</div>
	<div class="footer-group" aria-label="Quick links">
		<p class="footer-label mono">routes</p>
		<nav class="footer-links" aria-label="Quick links">
			{
				quickLinks.map((item) => {
					const isActive = isActivePath(item.path, Astro.url.pathname);

					return (
					<a
						href={item.path}
						class={`footer-link ${isActive ? 'active' : ''}`}
						aria-current={isActive ? 'page' : undefined}
					>
						<span class="footer-link-index mono" aria-hidden="true">{item.signal}</span>
						<span class="footer-link-label">{item.label}</span>
					</a>
					);
				})
			}
		</nav>
	</div>
	<div class="footer-group" aria-label="Social links">
		<p class="footer-label mono">channels</p>
		<nav class="footer-links footer-links-social" aria-label="Social links">
			{
				socialLinks.map((item) => (
					<a href={item.href} class="footer-link" target="_blank" rel="noreferrer">
						<span class="footer-link-index mono" aria-hidden="true">{item.signal}</span>
						<span class="footer-link-label">{item.label}</span>
					</a>
				))
			}
		</nav>
	</div>
</footer>

<style>
	.terminal-footer {
		border-top: 1px solid color-mix(in srgb, var(--border-strong) 68%, transparent);
		padding: clamp(1.1rem, 2vw, 1.5rem) clamp(1rem, 2.4vw, 1.75rem) clamp(1.5rem, 3vw, 2rem);
		display: grid;
		grid-template-columns: minmax(0, 1.4fr) repeat(2, minmax(0, 1fr));
		gap: 1.5rem;
		background:
			linear-gradient(180deg, color-mix(in srgb, var(--surface) 76%, transparent) 0%, color-mix(in srgb, var(--surface-soft) 88%, transparent) 100%);
	}

	.footer-kicker,
	.footer-title,
	.footer-label {
		margin: 0 0 0.4rem;
	}

	.footer-kicker,
	.footer-label {
		color: var(--accent-2);
		font-size: 0.72rem;
		text-transform: uppercase;
		letter-spacing: 0.14em;
	}

	.footer-title {
		color: var(--text-main);
		font-size: 1.4rem;
		font-weight: 700;
		letter-spacing: -0.04em;
	}

	.footer-copy {
		margin: 0;
		color: var(--text-muted);
		max-width: 28rem;
		font-family: 'Exo 2', sans-serif;
		font-size: 0.95rem;
	}

	.footer-meta-note {
		margin: 0.85rem 0 0;
		color: var(--text-soft);
		font-size: 0.66rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
	}

	.footer-group {
		padding-left: 1.2rem;
		border-left: 1px solid color-mix(in srgb, var(--border-strong) 58%, transparent);
		display: grid;
		align-content: start;
	}

	.footer-links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
	}

	.footer-link {
		display: inline-grid;
		grid-template-columns: auto auto;
		align-items: center;
		gap: 0.55rem;
		min-height: 2.4rem;
		padding: 0.55rem 0.8rem;
		border: 1px solid color-mix(in srgb, var(--border) 60%, transparent);
		border-radius: 999px;
		background: color-mix(in srgb, var(--surface) 45%, transparent);
		color: var(--text-muted);
		text-decoration: none;
		font-family: 'Azeret Mono', monospace;
		font-size: 0.76rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		box-shadow: inset 0 1px 0 color-mix(in srgb, var(--surface-strong) 36%, transparent);
	}

	.footer-link-index {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 1.55rem;
		height: 1.55rem;
		border-radius: 999px;
		border: 1px solid color-mix(in srgb, var(--border-strong) 48%, transparent);
		background: color-mix(in srgb, var(--surface-strong) 68%, transparent);
		color: var(--accent-2);
		font-size: 0.63rem;
		line-height: 1;
	}

	.footer-link:hover {
		color: var(--text-main);
		border-color: color-mix(in srgb, var(--border-strong) 72%, transparent);
		background: color-mix(in srgb, var(--surface-strong) 76%, transparent);
	}

	.footer-link:focus-visible {
		outline: 2px solid var(--accent);
		outline-offset: 3px;
		color: var(--text-main);
		border-color: color-mix(in srgb, var(--accent) 44%, var(--border));
		background: color-mix(in srgb, var(--surface-strong) 78%, var(--accent) 12%);
		box-shadow:
			inset 0 0 0 1px color-mix(in srgb, var(--accent-2) 18%, transparent),
			0 14px 28px color-mix(in srgb, var(--shadow-color) 24%, transparent);
	}

	.footer-link.active {
		color: var(--accent);
		border-color: color-mix(in srgb, var(--accent) 40%, var(--border));
		background: color-mix(in srgb, var(--surface-strong) 80%, var(--accent) 10%);
	}

	.footer-link.active .footer-link-index {
		border-color: color-mix(in srgb, var(--accent-2) 55%, transparent);
		background: color-mix(in srgb, var(--accent) 14%, var(--surface-strong));
	}

	@media (max-width: 768px) {
		.terminal-footer {
			grid-template-columns: 1fr;
		}

		.footer-group {
			padding-left: 0;
			padding-top: 1rem;
			border-left: 0;
			border-top: 1px solid color-mix(in srgb, var(--border-strong) 58%, transparent);
		}
	}
</style>
