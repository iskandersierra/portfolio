---
const quickLinks = [
	{ path: '/', label: 'Home' },
	{ path: '/blog', label: 'Blog' },
	{ path: '/projects', label: 'Projects' },
	{ path: '/about', label: 'About' },
];

const socialLinks = [
	{ href: 'https://github.com/iskandersierra', label: 'GitHub' },
	{ href: 'https://www.linkedin.com/in/iskandersierra/', label: 'LinkedIn' },
];

const isActivePath = (itemPath: string, currentPath: string) =>
	itemPath === '/'
		? currentPath === '/'
		: currentPath === itemPath || currentPath.startsWith(`${itemPath}/`);
---

<footer class="site-footer">
	<div class="footer-meta">
		<p class="footer-kicker mono">portfolio</p>
		<p class="footer-title">Iskander Sierra</p>
		<p class="footer-copy">Built for learning, shipping, and sharing practical engineering work.</p>
	</div>
	<div class="footer-group" aria-label="Quick links">
		<p class="footer-label mono">routes</p>
		<nav class="footer-links" aria-label="Quick links">
			{
				quickLinks.map((item) => {
					const isActive = isActivePath(item.path, Astro.url.pathname);

					return (
					<a
						href={item.path}
						class={`footer-link ${isActive ? 'active' : ''}`}
						aria-current={isActive ? 'page' : undefined}
					>
						<span class="footer-link-label">{item.label}</span>
					</a>
					);
				})
			}
		</nav>
	</div>
	<div class="footer-group" aria-label="Social links">
		<p class="footer-label mono">channels</p>
		<nav class="footer-links footer-links-social" aria-label="Social links">
			{
				socialLinks.map((item) => (
					<a href={item.href} class="footer-link" target="_blank" rel="noreferrer">
						<span class="footer-link-label">{item.label}</span>
					</a>
				))
			}
		</nav>
	</div>
</footer>

<style>
	.site-footer {
		border-top: 1px solid var(--border);
		padding: clamp(1.4rem, 2vw, 1.8rem) clamp(1rem, 3vw, 1.75rem) 0;
		display: grid;
		grid-template-columns: minmax(0, 1.4fr) repeat(2, minmax(0, 1fr));
		gap: 1.5rem;
		background: transparent;
	}

	.footer-kicker,
	.footer-title,
	.footer-label {
		margin: 0 0 0.4rem;
	}

	.footer-kicker,
	.footer-label {
		color: var(--text-soft);
		font-size: 0.72rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	.footer-title {
		color: var(--text-main);
		font-family: var(--font-display);
		font-size: 1.55rem;
		font-weight: 600;
		letter-spacing: -0.02em;
	}

	.footer-copy {
		margin: 0;
		color: var(--text-muted);
		max-width: 28rem;
		font-size: 0.95rem;
	}

	.footer-group {
		padding-left: 1.2rem;
		border-left: 1px solid var(--border);
		display: grid;
		align-content: start;
	}

	.footer-links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
	}

	.footer-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 2.2rem;
		padding: 0.35rem 0;
		border: 0;
		border-radius: 999px;
		background: transparent;
		color: var(--text-muted);
		text-decoration: none;
		font-family: var(--font-mono);
		font-size: 0.75rem;
		letter-spacing: 0.06em;
		text-transform: uppercase;
	}

	.footer-link-label {
		font-weight: 600;
	}

	.footer-link:hover {
		color: var(--accent);
	}

	.footer-link:focus-visible {
		outline: 2px solid var(--accent);
		outline-offset: 3px;
		color: var(--accent);
	}

	.footer-link.active {
		color: var(--accent);
		text-decoration: underline;
		text-decoration-thickness: 0.14em;
		text-underline-offset: 0.28em;
	}

	@media (max-width: 768px) {
		.site-footer {
			grid-template-columns: 1fr;
		}

		.footer-group {
			padding-left: 0;
			padding-top: 1rem;
			border-left: 0;
			border-top: 1px solid color-mix(in srgb, var(--border-strong) 58%, transparent);
		}
	}
</style>
