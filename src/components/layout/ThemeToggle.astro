<button
	id="theme-toggle"
	class="theme-toggle"
	type="button"
	aria-label="Switch to dark theme"
	aria-pressed="false"
>
	<span class="sr-only">Toggle theme</span>
	<svg
		class="sun"
		xmlns="http://www.w3.org/2000/svg"
		width="24"
		height="24"
		viewBox="0 0 24 24"
		fill="none"
		stroke="currentColor"
		stroke-width="2"
		stroke-linecap="round"
		stroke-linejoin="round"
	>
		<circle cx="12" cy="12" r="4"></circle>
		<path d="M12 2v2"></path>
		<path d="M12 20v2"></path>
		<path d="m4.93 4.93 1.41 1.41"></path>
		<path d="m17.66 17.66 1.41 1.41"></path>
		<path d="M2 12h2"></path>
		<path d="M20 12h2"></path>
		<path d="m6.34 17.66-1.41 1.41"></path>
		<path d="m19.07 4.93-1.41 1.41"></path>
	</svg>
	<svg
		class="moon"
		xmlns="http://www.w3.org/2000/svg"
		width="24"
		height="24"
		viewBox="0 0 24 24"
		fill="none"
		stroke="currentColor"
		stroke-width="2"
		stroke-linecap="round"
		stroke-linejoin="round"
	>
		<path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
	</svg>
</button>

<style>
	.theme-toggle {
		background: var(--surface);
		border: 1px solid var(--border);
		color: var(--text-muted);
		cursor: pointer;
		width: 2.75rem;
		height: 2.75rem;
		padding: 0.45rem;
		display: flex;
		align-items: center;
		justify-content: center;
		transition:
			border-color 0.2s ease,
			background-color 0.2s ease,
			color 0.2s ease,
			transform 0.2s ease;
	}

	.theme-toggle:hover {
		border-color: var(--accent);
		color: var(--accent);
	}

	.theme-toggle:focus-visible {
		outline: 2px solid var(--accent);
		outline-offset: 3px;
	}

	.theme-toggle svg {
		width: 1.15rem;
		height: 1.15rem;
	}

	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border-width: 0;
	}

	/* Display logic based on current theme */
	:global([data-theme='dark']) .sun {
		display: block;
	}
	:global([data-theme='dark']) .moon {
		display: none;
	}

	:global(html:not([data-theme='dark'])) .sun {
		display: none;
	}
	:global(html:not([data-theme='dark'])) .moon {
		display: block;
	}

	@media (prefers-reduced-motion: reduce) {
		.theme-toggle {
			transition: none;
		}
	}
</style>

<script>
	const themeToggleState = {
		controller: null as AbortController | null,
	};

	const syncToggleA11y = () => {
		const btn = document.getElementById('theme-toggle');
		if (!btn) return;
		const resolvedTheme = document.documentElement.getAttribute('data-theme') === 'dark' ? 'dark' : 'light';
		btn.setAttribute('aria-pressed', String(resolvedTheme === 'dark'));
		btn.setAttribute(
			'aria-label',
			resolvedTheme === 'dark' ? 'Switch to light theme' : 'Switch to dark theme',
		);
	};

	const handleToggleClick = () => {
		const resolvedTheme = document.documentElement.getAttribute('data-theme') === 'dark' ? 'dark' : 'light';
		const themeApi = (window as Window & {
			__portfolioTheme?: {
				setPreference?: (preference: 'light' | 'dark' | null) => void;
			};
		}).__portfolioTheme;

		themeApi?.setPreference?.(resolvedTheme === 'dark' ? 'light' : 'dark');
	};

	// We add this to run when View Transitions load the page as well (if used later)
	const initToggle = () => {
		themeToggleState.controller?.abort();
		themeToggleState.controller = new AbortController();

		const signal = themeToggleState.controller.signal;
		const btn = document.getElementById('theme-toggle');
		if (btn) {
			btn.addEventListener('click', handleToggleClick, { signal });
		}

		window.addEventListener('portfolio:theme-change', syncToggleA11y, { signal });
		syncToggleA11y();
	};

	initToggle();
	document.addEventListener('astro:page-load', initToggle);
</script>
