<div class="theme-toggle-shell" data-theme-toggle-root data-open="false">
	<button
		id="theme-toggle"
		class="theme-toggle"
		type="button"
		aria-haspopup="menu"
		aria-expanded="false"
		aria-controls="theme-menu"
		aria-label="Theme: System. Open theme menu"
		data-current-mode="system"
	>
		<span class="sr-only">Theme: System. Open theme menu</span>
		<span class="theme-toggle-copy" aria-hidden="true">
			<span class="theme-toggle-label mono">theme</span>
			<span class="theme-toggle-mode">system</span>
		</span>
		<span class="theme-toggle-icon" aria-hidden="true">
			<svg
				class="theme-icon theme-icon-light"
				xmlns="http://www.w3.org/2000/svg"
				width="24"
				height="24"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				stroke-linejoin="round"
			>
				<circle cx="12" cy="12" r="4"></circle>
				<path d="M12 2v2"></path>
				<path d="M12 20v2"></path>
				<path d="m4.93 4.93 1.41 1.41"></path>
				<path d="m17.66 17.66 1.41 1.41"></path>
				<path d="M2 12h2"></path>
				<path d="M20 12h2"></path>
				<path d="m6.34 17.66-1.41 1.41"></path>
				<path d="m19.07 4.93-1.41 1.41"></path>
			</svg>
			<svg
				class="theme-icon theme-icon-dark"
				xmlns="http://www.w3.org/2000/svg"
				width="24"
				height="24"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				stroke-linejoin="round"
			>
				<path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
			</svg>
			<svg
				class="theme-icon theme-icon-system"
				xmlns="http://www.w3.org/2000/svg"
				width="24"
				height="24"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				stroke-linejoin="round"
			>
				<rect x="3" y="4" width="18" height="12" rx="2"></rect>
				<path d="M8 20h8"></path>
				<path d="M12 16v4"></path>
			</svg>
		</span>
		<svg
			class="theme-toggle-caret"
			xmlns="http://www.w3.org/2000/svg"
			width="16"
			height="16"
			viewBox="0 0 24 24"
			fill="none"
			stroke="currentColor"
			stroke-width="2"
			stroke-linecap="round"
			stroke-linejoin="round"
			aria-hidden="true"
		>
			<path d="m6 9 6 6 6-6"></path>
		</svg>
	</button>
	<div id="theme-menu" class="theme-menu" role="menu" aria-label="Color theme" hidden>
		<button type="button" class="theme-option" role="menuitemradio" aria-checked="false" data-theme-option="light" tabindex="-1">
			<span class="theme-option-icon" aria-hidden="true">
				<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<circle cx="12" cy="12" r="4"></circle>
					<path d="M12 2v2"></path>
					<path d="M12 20v2"></path>
					<path d="m4.93 4.93 1.41 1.41"></path>
					<path d="m17.66 17.66 1.41 1.41"></path>
					<path d="M2 12h2"></path>
					<path d="M20 12h2"></path>
					<path d="m6.34 17.66-1.41 1.41"></path>
					<path d="m19.07 4.93-1.41 1.41"></path>
				</svg>
			</span>
			<span class="theme-option-copy">
				<span class="theme-option-label">Light</span>
				<span class="theme-option-meta mono">clear field</span>
			</span>
			<span class="theme-option-check" aria-hidden="true">•</span>
		</button>
		<button type="button" class="theme-option" role="menuitemradio" aria-checked="false" data-theme-option="dark" tabindex="-1">
			<span class="theme-option-icon" aria-hidden="true">
				<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
				</svg>
			</span>
			<span class="theme-option-copy">
				<span class="theme-option-label">Dark</span>
				<span class="theme-option-meta mono">deep field</span>
			</span>
			<span class="theme-option-check" aria-hidden="true">•</span>
		</button>
		<button type="button" class="theme-option" role="menuitemradio" aria-checked="false" data-theme-option="system" tabindex="-1">
			<span class="theme-option-icon" aria-hidden="true">
				<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<rect x="3" y="4" width="18" height="12" rx="2"></rect>
					<path d="M8 20h8"></path>
					<path d="M12 16v4"></path>
				</svg>
			</span>
			<span class="theme-option-copy">
				<span class="theme-option-label">System</span>
				<span class="theme-option-meta mono">adaptive sync</span>
			</span>
			<span class="theme-option-check" aria-hidden="true">•</span>
		</button>
	</div>
</div>

<style>
	.theme-toggle-shell {
		position: relative;
		flex: 0 0 auto;
	}

	.theme-toggle {
		background: var(--surface-soft);
		border: 1px solid var(--border);
		border-radius: var(--radius-md);
		color: var(--text-muted);
		cursor: pointer;
		min-width: 8rem;
		height: 2.5rem;
		padding: 0.45rem 0.75rem;
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.55rem;
		transition:
			border-color 0.2s ease,
			background-color 0.2s ease,
			color 0.2s ease,
			transform 0.2s ease,
			box-shadow 0.2s ease;
	}

	.theme-toggle-shell[data-open='true'] .theme-toggle,
	.theme-toggle:hover {
		border-color: var(--border-strong);
		color: var(--accent);
		box-shadow: var(--panel-shadow-soft);
	}

	.theme-toggle-shell[data-open='true'] .theme-toggle {
		background: var(--surface);
	}

	.theme-toggle:focus-visible {
		outline: 2px solid var(--accent);
		outline-offset: 3px;
	}

	.theme-toggle-copy {
		display: grid;
		justify-items: start;
		gap: 0.05rem;
		min-width: 0;
		flex: 0 1 auto;
	}

	.theme-toggle-label {
		font-size: 0.64rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--text-muted);
	}

	.theme-toggle-mode {
		font-size: 0.88rem;
		line-height: 1;
		text-transform: capitalize;
		color: var(--text-main);
	}

	.theme-toggle-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 1.8rem;
		height: 1.8rem;
		border-radius: 999px;
		border: 1px solid var(--border);
		background: var(--surface);
	}

	.theme-icon,
	.theme-toggle-caret {
		width: 1.15rem;
		height: 1.15rem;
	}

	.theme-icon {
		display: none;
	}

	.theme-toggle[data-current-mode='light'] .theme-icon-light,
	.theme-toggle[data-current-mode='dark'] .theme-icon-dark,
	.theme-toggle[data-current-mode='system'] .theme-icon-system {
		display: block;
	}

	.theme-toggle-caret {
		width: 0.9rem;
		height: 0.9rem;
		transition: transform 0.2s ease;
	}

	.theme-toggle-shell[data-open='true'] .theme-toggle-caret {
		transform: rotate(180deg);
	}

	.theme-menu {
		position: absolute;
		top: calc(100% + 0.45rem);
		right: 0;
		z-index: 20;
		width: min(13rem, calc(100vw - 2rem));
		padding: 0.45rem;
		border: 1px solid var(--border);
		border-radius: var(--radius-lg);
		background: var(--surface);
		box-shadow: var(--panel-shadow);
	}

	.theme-menu[hidden] {
		display: none;
	}

	.theme-option {
		width: 100%;
		border: 1px solid transparent;
		border-radius: 0.8rem;
		background: transparent;
		color: var(--text-muted);
		cursor: pointer;
		padding: 0.7rem 0.8rem;
		display: grid;
		grid-template-columns: auto 1fr auto;
		align-items: center;
		gap: 0.65rem;
		text-align: left;
		font: inherit;
		transition:
			border-color 0.2s ease,
			background-color 0.2s ease,
			color 0.2s ease;
	}

	.theme-option-copy {
		display: grid;
		gap: 0.15rem;
	}

	.theme-option-label {
		line-height: 1.1;
	}

	.theme-option-meta {
		font-size: 0.62rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--text-muted-strong);
	}

	.theme-option:hover,
	.theme-option:focus-visible {
		border-color: var(--border-strong);
		color: var(--text-main);
		outline: none;
	}

	.theme-option:focus-visible {
		background: var(--surface-soft);
	}

	.theme-option[aria-checked='true'] {
		color: var(--accent);
		border-color: var(--border-strong);
		background: var(--surface-soft);
	}

	.theme-option-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
	}

	.theme-option-check {
		opacity: 0;
		font-size: 1.15rem;
		line-height: 1;
	}

	.theme-option[aria-checked='true'] .theme-option-check {
		opacity: 1;
	}

	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border-width: 0;
	}

	@media (prefers-reduced-motion: reduce) {
		.theme-toggle,
		.theme-option,
		.theme-toggle-caret {
			transition: none;
		}
	}

	@media (max-width: 640px) {
		.theme-toggle {
			min-width: 3rem;
			padding-inline: 0.58rem;
			gap: 0.38rem;
		}

		.theme-toggle-copy {
			display: none;
		}

		.theme-toggle-icon {
			width: 1.68rem;
			height: 1.68rem;
		}

		.theme-toggle-caret {
			width: 0.8rem;
			height: 0.8rem;
		}
	}

	@media (max-width: 360px) {
		.theme-toggle {
			padding-inline: 0.5rem;
			gap: 0.3rem;
		}

		.theme-toggle-caret {
			display: none;
		}
	}
</style>

<script>
	const THEME_MODES = ['light', 'dark', 'system'] as const;
	type ThemeMode = (typeof THEME_MODES)[number];
	type ThemePreference = 'light' | 'dark' | null;

	const themeToggleState = {
		controller: null as AbortController | null,
	};

	const getThemeApi = () => {
		return (window as Window & {
			__portfolioTheme?: {
				getMode?: () => ThemeMode;
				getResolvedTheme?: () => 'light' | 'dark';
				setPreference?: (preference: ThemePreference) => void;
			};
		}).__portfolioTheme;
	};

	const getModeLabel = (mode: ThemeMode, resolvedTheme: 'light' | 'dark') => {
		if (mode === 'system') {
			return `Theme: System (${resolvedTheme} mode). Open theme menu`;
		}

		return `Theme: ${mode === 'dark' ? 'Dark' : 'Light'}. Open theme menu`;
	};

	const getVisibleModeLabel = (mode: ThemeMode) => {
		if (mode === 'system') {
			return 'System';
		}

		return mode === 'dark' ? 'Dark' : 'Light';
	};

	const getCurrentMode = (): ThemeMode => {
		const mode = getThemeApi()?.getMode?.();

		return THEME_MODES.includes(mode as ThemeMode) ? (mode as ThemeMode) : 'system';
	};

	const getResolvedTheme = (): 'light' | 'dark' => {
		return getThemeApi()?.getResolvedTheme?.() === 'dark' ? 'dark' : 'light';
	};

	const getThemePreference = (mode: ThemeMode): ThemePreference => {
		if (mode === 'system') {
			return null;
		}

		return mode;
	};

	const getMenuItems = (menu: HTMLElement) => {
		return Array.from(menu.querySelectorAll<HTMLButtonElement>('[data-theme-option]'));
	};

	const syncToggleUi = (root: HTMLElement, trigger: HTMLButtonElement, menu: HTMLElement) => {
		const mode = getCurrentMode();
		const resolvedTheme = getResolvedTheme();
		const label = getModeLabel(mode, resolvedTheme);

		root.dataset.currentMode = mode;
		root.dataset.resolvedTheme = resolvedTheme;
		trigger.dataset.currentMode = mode;
		trigger.setAttribute('aria-label', label);

		const srOnlyLabel = trigger.querySelector('.sr-only');
		if (srOnlyLabel) {
			srOnlyLabel.textContent = label;
		}

		const visibleLabel = trigger.querySelector('.theme-toggle-mode');
		if (visibleLabel) {
			visibleLabel.textContent = getVisibleModeLabel(mode);
		}

		for (const item of getMenuItems(menu)) {
			const isActive = item.dataset.themeOption === mode;
			item.setAttribute('aria-checked', String(isActive));
			item.tabIndex = isActive && !menu.hidden ? 0 : -1;
		}
	};

	const focusMenuItem = (menu: HTMLElement, mode: ThemeMode) => {
		const target = menu.querySelector<HTMLButtonElement>(`[data-theme-option="${mode}"]`);
		target?.focus();
	};

	const moveFocus = (menu: HTMLElement, direction: 'next' | 'previous' | 'first' | 'last') => {
		const items = getMenuItems(menu);
		if (!items.length) {
			return;
		}

		const activeIndex = items.findIndex((item) => item === document.activeElement);
		const currentIndex = activeIndex >= 0 ? activeIndex : items.findIndex((item) => item.getAttribute('aria-checked') === 'true');

		let nextIndex = currentIndex >= 0 ? currentIndex : 0;

		if (direction === 'next') {
			nextIndex = (nextIndex + 1) % items.length;
		} else if (direction === 'previous') {
			nextIndex = (nextIndex - 1 + items.length) % items.length;
		} else if (direction === 'first') {
			nextIndex = 0;
		} else {
			nextIndex = items.length - 1;
		}

		items.forEach((item, index) => {
			item.tabIndex = index === nextIndex ? 0 : -1;
		});
		items[nextIndex]?.focus();
	};

	const applyThemeSelection = (mode: ThemeMode) => {
		getThemeApi()?.setPreference?.(getThemePreference(mode));
	};

	const initToggle = () => {
		themeToggleState.controller?.abort();
		themeToggleState.controller = new AbortController();

		const signal = themeToggleState.controller.signal;
		const root = document.querySelector<HTMLElement>('[data-theme-toggle-root]');
		const trigger = document.getElementById('theme-toggle');
		const menu = document.getElementById('theme-menu');

		if (!(root instanceof HTMLElement) || !(trigger instanceof HTMLButtonElement) || !(menu instanceof HTMLElement)) {
			return;
		}

		const closeMenu = (restoreFocus = false) => {
			root.dataset.open = 'false';
			trigger.setAttribute('aria-expanded', 'false');
			menu.hidden = true;
			syncToggleUi(root, trigger, menu);

			if (restoreFocus) {
				trigger.focus();
			}
		};

		const openMenu = (focusMode = getCurrentMode()) => {
			root.dataset.open = 'true';
			trigger.setAttribute('aria-expanded', 'true');
			menu.hidden = false;
			syncToggleUi(root, trigger, menu);
			focusMenuItem(menu, focusMode);
		};

		closeMenu();

		trigger.addEventListener(
			'click',
			() => {
				if (trigger.getAttribute('aria-expanded') === 'true') {
					closeMenu();
					return;
				}

				openMenu();
			},
			{ signal },
		);

		trigger.addEventListener(
			'keydown',
			(event) => {
				if (event.key === 'ArrowDown' || event.key === 'Enter' || event.key === ' ') {
					event.preventDefault();
					openMenu();
					return;
				}

				if (event.key === 'ArrowUp') {
					event.preventDefault();
					openMenu(getCurrentMode());
					return;
				}

				if (event.key === 'Escape' && trigger.getAttribute('aria-expanded') === 'true') {
					event.preventDefault();
					closeMenu();
				}
			},
			{ signal },
		);

		menu.addEventListener(
			'click',
			(event) => {
				const target = event.target;
				if (!(target instanceof Element)) {
					return;
				}

				const option = target.closest<HTMLButtonElement>('[data-theme-option]');
				const mode = option?.dataset.themeOption as ThemeMode | undefined;
				if (!option || !mode || !THEME_MODES.includes(mode)) {
					return;
				}

				applyThemeSelection(mode);
				closeMenu(true);
			},
			{ signal },
		);

		menu.addEventListener(
			'keydown',
			(event) => {
				switch (event.key) {
					case 'ArrowDown':
						event.preventDefault();
						moveFocus(menu, 'next');
						break;
					case 'ArrowUp':
						event.preventDefault();
						moveFocus(menu, 'previous');
						break;
					case 'Home':
						event.preventDefault();
						moveFocus(menu, 'first');
						break;
					case 'End':
						event.preventDefault();
						moveFocus(menu, 'last');
						break;
					case 'Escape':
						event.preventDefault();
						closeMenu(true);
						break;
					case 'Tab':
						closeMenu();
						break;
					case 'Enter':
					case ' ':
						if (document.activeElement instanceof HTMLButtonElement) {
							const mode = document.activeElement.dataset.themeOption as ThemeMode | undefined;
							if (mode && THEME_MODES.includes(mode)) {
								event.preventDefault();
								applyThemeSelection(mode);
								closeMenu(true);
							}
						}
						break;
				}
			},
			{ signal },
		);

		document.addEventListener(
			'click',
			(event) => {
				const target = event.target;
				if (target instanceof Node && !root.contains(target)) {
					closeMenu();
				}
			},
			{ signal },
		);

		window.addEventListener(
			'portfolio:theme-change',
			() => {
				syncToggleUi(root, trigger, menu);
			},
			{ signal },
		);

		syncToggleUi(root, trigger, menu);
	};

	initToggle();
	document.addEventListener('astro:page-load', initToggle);
</script>
