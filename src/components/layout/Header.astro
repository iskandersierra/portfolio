---
import ThemeToggle from './ThemeToggle.astro';

const navItems = [
	{ path: '/', label: 'Home' },
	{ path: '/blog', label: 'Blog' },
	{ path: '/projects', label: 'Projects' },
	{ path: '/about', label: 'About' },
];

const isActivePath = (itemPath: string, currentPath: string) =>
	itemPath === '/'
		? currentPath === '/'
		: currentPath === itemPath || currentPath.startsWith(`${itemPath}/`);
---

<header class="site-header">
	<div class="site-header-top">
		<div class="brand">
			<a href="/" class="logo">iskander.sierra</a>
		</div>
		<nav class="nav-links nav-links-desktop" aria-label="Primary">
			{
				navItems.map((item) => {
					const isActive = isActivePath(item.path, Astro.url.pathname);

					return (
						<a
							href={item.path}
							class={`nav-link ${isActive ? 'active' : ''}`}
							aria-current={isActive ? 'page' : undefined}
						>
							<span class="nav-link-label">{item.label}</span>
						</a>
					);
				})
			}
		</nav>
		<div class="actions">
			<ThemeToggle />
			<button
				type="button"
				class="nav-toggle"
				data-mobile-nav-toggle
				aria-expanded="false"
				aria-controls="mobile-navigation"
				aria-label="Open navigation menu"
			>
				<span class="nav-toggle-label" aria-hidden="true">menu</span>
				<span class="nav-toggle-icon" aria-hidden="true">
					<span class="nav-toggle-line"></span>
					<span class="nav-toggle-line"></span>
					<span class="nav-toggle-line"></span>
				</span>
				<span class="sr-only">Toggle navigation</span>
			</button>
		</div>
	</div>
	<div class="mobile-nav-shell" data-mobile-nav hidden>
		<nav id="mobile-navigation" class="mobile-nav-panel" aria-label="Mobile primary">
			{
				navItems.map((item) => {
					const isActive = isActivePath(item.path, Astro.url.pathname);

					return (
						<a
							href={item.path}
							data-astro-reload
							class={`mobile-nav-link ${isActive ? 'active' : ''}`}
							aria-current={isActive ? 'page' : undefined}
						>
							<span>{item.label}</span>
						</a>
					);
				})
			}
		</nav>
	</div>
</header>

<style>
	.site-header {
		padding: 0 clamp(1rem, 3vw, 1.75rem);
		margin-bottom: clamp(1.25rem, 3vw, 2rem);
	}

	.site-header-top {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
		align-items: center;
		gap: 1rem;
		width: 100%;
		padding: clamp(1rem, 2vw, 1.2rem) 0;
		border-bottom: 1px solid var(--border);
	}

	.brand {
		flex-shrink: 0;
		justify-self: start;
		display: grid;
		gap: 0.28rem;
		min-width: 0;
	}

	.logo {
		color: var(--text-main);
		font-family: var(--font-display);
		font-weight: 600;
		text-decoration: none;
		font-size: clamp(1.15rem, 1rem + 0.5vw, 1.4rem);
		white-space: nowrap;
		letter-spacing: -0.02em;
		transition: color 0.2s ease;
	}

	.logo:hover {
		color: var(--accent);
		text-decoration: none;
	}

	.nav-links {
		display: flex;
		gap: 0.75rem;
	}

	.nav-links-desktop {
		align-items: center;
		justify-content: center;
		justify-self: center;
		white-space: nowrap;
	}

	.nav-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 2.25rem;
		padding: 0.35rem 0.1rem;
		border: 0;
		border-radius: 0;
		background: transparent;
		color: var(--text-muted);
		text-decoration: none;
		white-space: nowrap;
		letter-spacing: 0;
		text-transform: none;
		font-size: 0.95rem;
		position: relative;
		overflow: hidden;
	}

	.nav-link::after {
		content: '';
		position: absolute;
		bottom: 0.1rem;
		left: 0;
		right: 0;
		height: 1px;
		background: var(--accent);
		transform: scaleX(0);
		transform-origin: left center;
		transition: transform 0.22s cubic-bezier(0.22, 1, 0.36, 1);
		border-radius: 999px;
	}

	.nav-link-label {
		color: inherit;
		font-weight: 500;
	}

	.nav-link:hover {
		color: var(--text-main);
		text-decoration: none;
	}

	.nav-link:hover::after {
		transform: scaleX(1);
	}

	.nav-link.active {
		color: var(--accent);
	}

	.nav-link.active::after {
		transform: scaleX(1);
	}

	.actions {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		flex-shrink: 0;
		justify-self: end;
		min-width: 0;
	}

	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border-width: 0;
	}

	.nav-toggle {
		display: none;
		grid-template-columns: auto auto;
		align-items: center;
		justify-content: center;
		column-gap: 0.55rem;
		min-width: 5rem;
		height: 2.5rem;
		padding: 0.65rem 0.8rem;
		border: 1px solid var(--border);
		border-radius: var(--radius-md);
		background: var(--surface-soft);
		color: var(--text-main);
		cursor: pointer;
		transition:
			border-color 0.2s ease,
			background-color 0.2s ease,
			color 0.2s ease,
			transform 0.2s ease,
			box-shadow 0.2s ease;
	}

	.nav-toggle-icon {
		display: grid;
		grid-template-rows: repeat(3, 1px);
		align-content: center;
		row-gap: 0.26rem;
		width: 1rem;
		flex-shrink: 0;
	}

	.nav-toggle:hover {
		border-color: var(--border-strong);
		color: var(--accent);
		box-shadow: var(--panel-shadow-soft);
	}

	.nav-toggle:focus-visible,
	.nav-link:focus-visible,
	.mobile-nav-link:focus-visible,
	.logo:focus-visible {
		outline: 2px solid var(--accent);
		outline-offset: 3px;
	}

	.nav-toggle-line {
		display: block;
		width: 100%;
		min-width: 0;
		height: 1px;
		background: currentColor;
	}

	.nav-toggle-label {
		font-size: 0.66rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.mobile-nav-shell {
		margin-top: 1rem;
		padding-top: 1rem;
		border-top: 1px solid var(--border);
	}

	.mobile-nav-panel {
		display: grid;
		gap: 0.75rem;
	}

	.mobile-nav-link {
		display: inline-flex;
		align-items: center;
		justify-content: space-between;
		padding: 0.85rem 1rem;
		border: 1px solid var(--border);
		border-radius: var(--radius-lg);
		background: var(--surface);
		color: var(--text-muted);
		text-decoration: none;
		text-transform: none;
		font-size: 0.95rem;
		letter-spacing: 0;
	}

	.mobile-nav-link.active {
		color: var(--accent);
		border-color: var(--border-strong);
		background: var(--surface-soft);
	}

	@media (max-width: 720px) {
		.site-header {
			gap: 1rem;
			align-items: stretch;
		}

		.site-header-top {
			display: grid;
			grid-template-columns: minmax(0, 1fr) auto;
			align-items: start;
			gap: 0.65rem;
			width: 100%;
		}

		.brand {
			display: grid;
			gap: 0.2rem;
			min-width: 0;
		}

		.logo {
			font-size: 1rem;
		}

		.actions {
			justify-content: flex-end;
			align-self: start;
			gap: 0.45rem;
		}

		.header-status {
			display: none;
		}

		.nav-toggle {
			min-width: 4.65rem;
			column-gap: 0.48rem;
			padding-inline: 0.7rem;
		}

		.nav-toggle-icon {
			row-gap: 0.24rem;
			width: 0.92rem;
		}

		.site-header[data-mobile-nav-ready='true'] .nav-links-desktop {
			display: none;
		}

		.site-header[data-mobile-nav-ready='true'] .nav-toggle {
			display: inline-flex;
		}
	}

	@media (max-width: 360px) {
		.nav-toggle {
			min-width: 4.2rem;
			column-gap: 0.42rem;
			padding-inline: 0.62rem;
		}

		.nav-toggle-icon {
			row-gap: 0.22rem;
			width: 0.84rem;
		}

		.nav-toggle-label {
			font-size: 0.62rem;
		}
	}

	@media (min-width: 721px) {
		.mobile-nav-shell {
			display: none !important;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.nav-toggle {
			transition: none;
		}
	}
</style>

<script>
	const mobileNavState = {
		controller: null as AbortController | null,
	};

	const initMobileNav = () => {
		mobileNavState.controller?.abort();
		mobileNavState.controller = new AbortController();

		const signal = mobileNavState.controller.signal;
		const header = document.querySelector('.site-header');
		const toggle = document.querySelector('[data-mobile-nav-toggle]');
		const panel = document.querySelector('[data-mobile-nav]');
		const desktopMedia = window.matchMedia('(min-width: 721px)');

		if (!(header instanceof HTMLElement)) {
			return;
		}

		if (!(toggle instanceof HTMLButtonElement) || !(panel instanceof HTMLElement)) {
			return;
		}

		header.setAttribute('data-mobile-nav-ready', 'true');

		const closeMenu = () => {
			const activeElement = document.activeElement;
			const shouldRestoreFocus = activeElement instanceof Node && panel.contains(activeElement);

			panel.hidden = true;

			if (shouldRestoreFocus) {
				toggle.focus();
			}

			toggle.setAttribute('aria-expanded', 'false');
			toggle.setAttribute('aria-label', 'Open navigation menu');
			document.body.removeAttribute('data-mobile-nav-open');
		};

		const openMenu = () => {
			panel.hidden = false;
			toggle.setAttribute('aria-expanded', 'true');
			toggle.setAttribute('aria-label', 'Close navigation menu');
			document.body.setAttribute('data-mobile-nav-open', 'true');
		};

		const handlePanelNavigation = (event: Event) => {
			const target = event.target;

			if (!(target instanceof Element)) {
				return;
			}

			if (target.closest('a[href]')) {
				closeMenu();
			}
		};

		const syncViewport = () => {
			if (desktopMedia.matches) {
				closeMenu();
			}
		};

		closeMenu();

		toggle.addEventListener(
			'click',
			() => {
				if (toggle.getAttribute('aria-expanded') === 'true') {
					closeMenu();
					return;
				}

				openMenu();
			},
			{ signal },
		);

		panel.addEventListener('click', handlePanelNavigation, { signal });

		document.addEventListener(
			'keydown',
			(event) => {
				if (event.key === 'Escape') {
					closeMenu();
				}
			},
			{ signal },
		);

		document.addEventListener(
			'click',
			(event) => {
				const target = event.target;

				if (target instanceof Node && !header.contains(target)) {
					closeMenu();
				}
			},
			{ signal },
		);

		desktopMedia.addEventListener('change', syncViewport, { signal });
	};

	initMobileNav();
	document.addEventListener('astro:page-load', initMobileNav);
</script>
