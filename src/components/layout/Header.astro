---
import ThemeToggle from './ThemeToggle.astro';

const navItems = [
	{ path: '/', label: 'Home' },
	{ path: '/about', label: 'About' },
	{ path: '/blog', label: 'Blog' },
	{ path: '/tools', label: 'Tools' },
];

const isActivePath = (itemPath: string, currentPath: string) =>
	itemPath === '/'
		? currentPath === '/'
		: currentPath === itemPath || currentPath.startsWith(`${itemPath}/`);
---

<header class="terminal-header mono">
	<div class="brand">
		<a href="/" class="logo">~/iskander</a>
	</div>
	<nav class="nav-links">
		{
			navItems.map((item) => {
				const isActive = isActivePath(item.path, Astro.url.pathname);

				return (
					<a
						href={item.path}
						class={`nav-link ${isActive ? 'active' : ''}`}
						aria-current={isActive ? 'page' : undefined}
					>
						{item.label}
					</a>
				);
			})
		}
	</nav>
	<div class="actions">
		<ThemeToggle />
	</div>
</header>

<style>
	.logo {
		color: var(--text-main);
		font-weight: 600;
		text-decoration: none;
		font-size: 1.1rem;
	}

	.logo:hover {
		color: var(--accent);
		text-decoration: none;
	}

	.nav-links {
		display: flex;
		gap: 1.5rem;
	}

	.nav-link {
		color: var(--text-muted);
		text-decoration: none;
	}

	.nav-link:hover {
		color: var(--text-main);
		text-decoration: none;
	}

	.nav-link.active {
		color: var(--accent);
		border-bottom: 2px solid var(--accent);
	}

	@media (max-width: 640px) {
		.terminal-header {
			flex-direction: column;
			gap: 1rem;
		}
		.nav-links {
			flex-wrap: wrap;
			justify-content: center;
		}
	}
</style>
