---
import ThemeToggle from './ThemeToggle.astro';

const navItems = [
	{ path: '/', label: 'Home' },
	{ path: '/blog', label: 'Blog' },
	{ path: '/projects', label: 'Projects' },
	{ path: '/about', label: 'About' },
];

const isActivePath = (itemPath: string, currentPath: string) =>
	itemPath === '/'
		? currentPath === '/'
		: currentPath === itemPath || currentPath.startsWith(`${itemPath}/`);
---

<header class="terminal-header">
	<div class="terminal-header-top">
		<div class="brand">
			<a href="/" class="logo">iskander.sierra</a>
		</div>
		<nav class="nav-links nav-links-desktop mono" aria-label="Primary">
			{
				navItems.map((item) => {
					const isActive = isActivePath(item.path, Astro.url.pathname);

					return (
						<a
							href={item.path}
							class={`nav-link ${isActive ? 'active' : ''}`}
							aria-current={isActive ? 'page' : undefined}
						>
							<span class="nav-link-label">{item.label}</span>
						</a>
					);
				})
			}
		</nav>
		<div class="actions">
			<ThemeToggle />
			<button
				type="button"
				class="nav-toggle"
				data-mobile-nav-toggle
				aria-expanded="false"
				aria-controls="mobile-navigation"
				aria-label="Open navigation menu"
			>
				<span class="nav-toggle-label mono" aria-hidden="true">menu</span>
				<span class="nav-toggle-icon" aria-hidden="true">
					<span class="nav-toggle-line"></span>
					<span class="nav-toggle-line"></span>
					<span class="nav-toggle-line"></span>
				</span>
				<span class="sr-only">Toggle navigation</span>
			</button>
		</div>
	</div>
	<div class="mobile-nav-shell" data-mobile-nav hidden>
		<nav id="mobile-navigation" class="mobile-nav-panel" aria-label="Mobile primary">
			{
				navItems.map((item) => {
					const isActive = isActivePath(item.path, Astro.url.pathname);

					return (
						<a
							href={item.path}
							data-astro-reload
							class={`mobile-nav-link ${isActive ? 'active' : ''}`}
							aria-current={isActive ? 'page' : undefined}
						>
							<span>{item.label}</span>
						</a>
					);
				})
			}
		</nav>
	</div>
</header>

<style>
	.terminal-header-top {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
		align-items: center;
		gap: 1rem;
		width: 100%;
	}

	.terminal-header {
		display: flex;
		flex-direction: column;
		align-items: stretch;
		position: relative;
		z-index: 2;
	}

	.brand {
		flex-shrink: 0;
		justify-self: start;
		display: grid;
		gap: 0.28rem;
		min-width: 0;
	}

	.logo {
		color: var(--text-main);
		font-weight: 700;
		text-decoration: none;
		font-size: clamp(1.15rem, 1rem + 0.5vw, 1.45rem);
		white-space: nowrap;
		letter-spacing: -0.04em;
		transition: color 0.2s ease, text-shadow 0.2s ease;
	}

	.logo:hover {
		color: var(--accent);
		text-shadow: 0 0 18px var(--accent-glow, rgba(23, 168, 225, 0.22));
		text-decoration: none;
	}

	.nav-links {
		display: flex;
		gap: 0.75rem;
	}

	.nav-links-desktop {
		align-items: center;
		justify-content: center;
		justify-self: center;
		white-space: nowrap;
	}

	.nav-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 2.7rem;
		padding: 0.72rem 1rem;
		border: 1px solid color-mix(in srgb, var(--border) 60%, transparent);
		border-radius: 999px;
		background: color-mix(in srgb, var(--surface) 45%, transparent);
		color: var(--text-muted);
		text-decoration: none;
		white-space: nowrap;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		font-size: 0.78rem;
		box-shadow: inset 0 1px 0 color-mix(in srgb, var(--surface-strong) 36%, transparent);
		position: relative;
		overflow: hidden;
	}

	.nav-link::after {
		content: '';
		position: absolute;
		bottom: 0.45rem;
		left: 1rem;
		right: 1rem;
		height: 1px;
		background: var(--accent);
		transform: scaleX(0);
		transform-origin: left center;
		transition: transform 0.22s cubic-bezier(0.22, 1, 0.36, 1);
		border-radius: 999px;
	}

	.nav-link-label {
		color: inherit;
		font-weight: 600;
	}

	.nav-link:hover {
		color: var(--text-main);
		border-color: color-mix(in srgb, var(--border-strong) 76%, transparent);
		background: color-mix(in srgb, var(--surface-strong) 82%, transparent);
		text-decoration: none;
	}

	.nav-link:hover::after {
		transform: scaleX(1);
	}

	.nav-link.active {
		color: var(--accent);
		border-color: color-mix(in srgb, var(--accent) 40%, var(--border));
		background: color-mix(in srgb, var(--surface-strong) 76%, var(--accent) 10%);
		isolation: isolate;
		box-shadow:
			inset 0 0 0 1px color-mix(in srgb, var(--accent-2) 18%, transparent),
			0 14px 28px color-mix(in srgb, var(--shadow-color) 12%, transparent);
	}

	.nav-link.active::before {
		content: '';
		display: inline-block;
		width: 0.48rem;
		height: 0.48rem;
		border-radius: 999px;
		background: radial-gradient(
			circle,
			var(--accent-2) 0 24%,
			color-mix(in srgb, var(--accent-2) 78%, var(--accent)) 25% 42%,
			color-mix(in srgb, var(--accent) 26%, transparent) 43% 68%,
			transparent 69%
		);
		margin-right: 0.85rem;
		filter: drop-shadow(0 0 10px color-mix(in srgb, var(--accent-glow) 90%, transparent));
		animation: pulse-node 2.6s ease-in-out infinite;
		flex-shrink: 0;
	}

	.nav-link.active::after {
		display: none;
	}

	.actions {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		flex-shrink: 0;
		justify-self: end;
		min-width: 0;
	}

	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border-width: 0;
	}

	.nav-toggle {
		display: none;
		grid-template-columns: auto auto;
		align-items: center;
		justify-content: center;
		column-gap: 0.55rem;
		min-width: 5.4rem;
		height: 2.75rem;
		padding: 0.65rem 0.8rem;
		border: 1px solid color-mix(in srgb, var(--border-strong) 65%, transparent);
		border-radius: 1rem;
		background: color-mix(in srgb, var(--surface-strong) 78%, transparent);
		color: var(--text-main);
		cursor: pointer;
		transition:
			border-color 0.2s ease,
			background-color 0.2s ease,
			color 0.2s ease,
			transform 0.2s ease,
			box-shadow 0.2s ease;
	}

	.nav-toggle-icon {
		display: grid;
		grid-template-rows: repeat(3, 1px);
		align-content: center;
		row-gap: 0.26rem;
		width: 1rem;
		flex-shrink: 0;
	}

	.nav-toggle:hover {
		border-color: var(--accent);
		color: var(--accent);
		box-shadow: 0 14px 28px color-mix(in srgb, var(--shadow-color) 28%, transparent);
	}

	.nav-toggle:focus-visible,
	.nav-link:focus-visible,
	.mobile-nav-link:focus-visible,
	.logo:focus-visible {
		outline: 2px solid var(--accent);
		outline-offset: 3px;
	}

	.nav-toggle-line {
		display: block;
		width: 100%;
		min-width: 0;
		height: 1px;
		background: currentColor;
	}

	.nav-toggle-label {
		font-size: 0.68rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	.mobile-nav-shell {
		margin-top: 1rem;
		padding-top: 1rem;
		border-top: 1px solid color-mix(in srgb, var(--border-strong) 68%, transparent);
	}

	.mobile-nav-panel {
		display: grid;
		gap: 0.75rem;
	}

	.mobile-nav-link {
		display: inline-flex;
		align-items: center;
		justify-content: space-between;
		padding: 0.85rem 1rem;
		border: 1px solid color-mix(in srgb, var(--border-strong) 60%, transparent);
		border-radius: 1rem;
		background: color-mix(in srgb, var(--surface-strong) 78%, transparent);
		color: var(--text-muted);
		text-decoration: none;
		text-transform: uppercase;
		font-size: 0.82rem;
		letter-spacing: 0.08em;
	}

	.mobile-nav-link.active {
		color: var(--accent);
		border-color: var(--accent);
		box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--accent-2) 20%, transparent);
	}

	@media (max-width: 720px) {
		.terminal-header {
			gap: 1rem;
			align-items: stretch;
		}

		.terminal-header-top {
			display: grid;
			grid-template-columns: minmax(0, 1fr) auto;
			align-items: start;
			gap: 0.65rem;
			width: 100%;
		}

		.brand {
			display: grid;
			gap: 0.2rem;
			min-width: 0;
		}

		.logo {
			font-size: 1rem;
		}

		.actions {
			justify-content: flex-end;
			align-self: start;
			gap: 0.45rem;
		}

		.header-status {
			display: none;
		}

		.nav-toggle {
			min-width: 4.65rem;
			column-gap: 0.48rem;
			padding-inline: 0.7rem;
		}

		.nav-toggle-icon {
			row-gap: 0.24rem;
			width: 0.92rem;
		}

		.terminal-header[data-mobile-nav-ready='true'] .nav-links-desktop {
			display: none;
		}

		.terminal-header[data-mobile-nav-ready='true'] .nav-toggle {
			display: inline-flex;
		}
	}

	@media (max-width: 360px) {
		.nav-toggle {
			min-width: 4.2rem;
			column-gap: 0.42rem;
			padding-inline: 0.62rem;
		}

		.nav-toggle-icon {
			row-gap: 0.22rem;
			width: 0.84rem;
		}

		.nav-toggle-label {
			font-size: 0.62rem;
		}
	}

	@media (min-width: 721px) {
		.mobile-nav-shell {
			display: none !important;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.nav-link.active::before {
			animation: none;
		}

		.nav-toggle {
			transition: none;
		}
	}
</style>

<script>
	const mobileNavState = {
		controller: null as AbortController | null,
	};

	const initMobileNav = () => {
		mobileNavState.controller?.abort();
		mobileNavState.controller = new AbortController();

		const signal = mobileNavState.controller.signal;
		const header = document.querySelector('.terminal-header');
		const toggle = document.querySelector('[data-mobile-nav-toggle]');
		const panel = document.querySelector('[data-mobile-nav]');
		const desktopMedia = window.matchMedia('(min-width: 721px)');

		if (!(header instanceof HTMLElement)) {
			return;
		}

		if (!(toggle instanceof HTMLButtonElement) || !(panel instanceof HTMLElement)) {
			return;
		}

		header.setAttribute('data-mobile-nav-ready', 'true');

		const closeMenu = () => {
			const activeElement = document.activeElement;
			const shouldRestoreFocus = activeElement instanceof Node && panel.contains(activeElement);

			panel.hidden = true;

			if (shouldRestoreFocus) {
				toggle.focus();
			}

			toggle.setAttribute('aria-expanded', 'false');
			toggle.setAttribute('aria-label', 'Open navigation menu');
			document.body.removeAttribute('data-mobile-nav-open');
		};

		const openMenu = () => {
			panel.hidden = false;
			toggle.setAttribute('aria-expanded', 'true');
			toggle.setAttribute('aria-label', 'Close navigation menu');
			document.body.setAttribute('data-mobile-nav-open', 'true');
		};

		const handlePanelNavigation = (event: Event) => {
			const target = event.target;

			if (!(target instanceof Element)) {
				return;
			}

			if (target.closest('a[href]')) {
				closeMenu();
			}
		};

		const syncViewport = () => {
			if (desktopMedia.matches) {
				closeMenu();
			}
		};

		closeMenu();

		toggle.addEventListener(
			'click',
			() => {
				if (toggle.getAttribute('aria-expanded') === 'true') {
					closeMenu();
					return;
				}

				openMenu();
			},
			{ signal },
		);

		panel.addEventListener('click', handlePanelNavigation, { signal });

		document.addEventListener(
			'keydown',
			(event) => {
				if (event.key === 'Escape') {
					closeMenu();
				}
			},
			{ signal },
		);

		document.addEventListener(
			'click',
			(event) => {
				const target = event.target;

				if (target instanceof Node && !header.contains(target)) {
					closeMenu();
				}
			},
			{ signal },
		);

		desktopMedia.addEventListener('change', syncViewport, { signal });
	};

	initMobileNav();
	document.addEventListener('astro:page-load', initMobileNav);
</script>
