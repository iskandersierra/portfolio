---
import ThemeToggle from './ThemeToggle.astro';

const navItems = [
	{ path: '/', label: 'Home', signal: '01' },
	{ path: '/about', label: 'About', signal: '02' },
	{ path: '/blog', label: 'Blog', signal: '03' },
	{ path: '/tools', label: 'Tools', signal: '04' },
];

const isActivePath = (itemPath: string, currentPath: string) =>
	itemPath === '/'
		? currentPath === '/'
		: currentPath === itemPath || currentPath.startsWith(`${itemPath}/`);
---

<header class="terminal-header">
	<div class="terminal-header-top">
		<div class="brand">
			<p class="brand-kicker mono">signal graph</p>
			<a href="/" class="logo">iskander.sierra</a>
			<p class="brand-meta mono">systems / writing / tools</p>
		</div>
		<nav class="nav-links nav-links-desktop mono" aria-label="Primary">
			{
				navItems.map((item) => {
					const isActive = isActivePath(item.path, Astro.url.pathname);

					return (
						<a
							href={item.path}
							class={`nav-link ${isActive ? 'active' : ''}`}
							aria-current={isActive ? 'page' : undefined}
						>
							<span class="nav-link-index" aria-hidden="true">{item.signal}</span>
							<span class="nav-link-label">{item.label}</span>
						</a>
					);
				})
			}
		</nav>
		<div class="actions">
			<p class="header-status mono" aria-hidden="true">
				<span class="header-status-dot"></span>
				<span class="header-status-copy">
					<span>control layer</span>
					<span>live</span>
				</span>
			</p>
			<ThemeToggle />
			<button
				type="button"
				class="nav-toggle"
				data-mobile-nav-toggle
				aria-expanded="false"
				aria-controls="mobile-navigation"
				aria-label="Open navigation menu"
			>
				<span class="nav-toggle-label mono" aria-hidden="true">menu</span>
				<span class="nav-toggle-line"></span>
				<span class="nav-toggle-line"></span>
				<span class="nav-toggle-line"></span>
				<span class="sr-only">Toggle navigation</span>
			</button>
		</div>
	</div>
	<div class="mobile-nav-shell" data-mobile-nav hidden>
		<nav id="mobile-navigation" class="mobile-nav-panel" aria-label="Mobile primary">
			{
				navItems.map((item) => {
					const isActive = isActivePath(item.path, Astro.url.pathname);

					return (
						<a
							href={item.path}
							data-astro-reload
							class={`mobile-nav-link ${isActive ? 'active' : ''}`}
							aria-current={isActive ? 'page' : undefined}
						>
							<span class="mobile-nav-link-index mono" aria-hidden="true">{item.signal}</span>
							<span>{item.label}</span>
						</a>
					);
				})
			}
		</nav>
	</div>
</header>

<style>
	.terminal-header-top {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
		align-items: center;
		gap: 1rem;
		width: 100%;
	}

	.terminal-header {
		display: flex;
		flex-direction: column;
		align-items: stretch;
		position: relative;
		z-index: 2;
	}

	.brand {
		flex-shrink: 0;
		justify-self: start;
		display: grid;
		gap: 0.28rem;
		min-width: 0;
	}

	.brand-kicker {
		margin: 0;
		font-size: 0.72rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--accent-2);
	}

	.brand-meta {
		margin: 0;
		font-size: 0.68rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--text-soft);
	}

	.logo {
		color: var(--text-main);
		font-weight: 700;
		text-decoration: none;
		font-size: clamp(1.15rem, 1rem + 0.5vw, 1.45rem);
		white-space: nowrap;
		letter-spacing: -0.04em;
	}

	.logo:hover {
		color: var(--accent);
		text-decoration: none;
	}

	.nav-links {
		display: flex;
		gap: 0.75rem;
	}

	.nav-links-desktop {
		align-items: center;
		justify-content: center;
		justify-self: center;
		white-space: nowrap;
	}

	.nav-link {
		display: grid;
		grid-template-columns: auto auto;
		align-items: center;
		justify-content: center;
		min-height: 2.7rem;
		gap: 0.5rem;
		padding: 0.72rem 0.95rem;
		border: 1px solid color-mix(in srgb, var(--border) 60%, transparent);
		border-radius: 999px;
		background: color-mix(in srgb, var(--surface) 45%, transparent);
		color: var(--text-muted);
		text-decoration: none;
		white-space: nowrap;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		font-size: 0.78rem;
		box-shadow: inset 0 1px 0 color-mix(in srgb, var(--surface-strong) 36%, transparent);
	}

	.nav-link-index {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 1.5rem;
		height: 1.5rem;
		border-radius: 999px;
		border: 1px solid color-mix(in srgb, var(--border-strong) 48%, transparent);
		background: color-mix(in srgb, var(--surface-strong) 68%, transparent);
		color: var(--accent-2);
		font-size: 0.63rem;
		line-height: 1;
	}

	.nav-link-label {
		color: inherit;
	}

	.nav-link:hover {
		color: var(--text-main);
		border-color: color-mix(in srgb, var(--border-strong) 76%, transparent);
		background: color-mix(in srgb, var(--surface-strong) 82%, transparent);
		text-decoration: none;
	}

	.nav-link.active {
		color: var(--accent);
		border-color: color-mix(in srgb, var(--accent) 40%, var(--border));
		background: color-mix(in srgb, var(--surface-strong) 76%, var(--accent) 10%);
		box-shadow:
			inset 0 0 0 1px color-mix(in srgb, var(--accent-2) 18%, transparent),
			0 14px 28px color-mix(in srgb, var(--shadow-color) 12%, transparent);
	}

	.nav-link.active .nav-link-index {
		border-color: color-mix(in srgb, var(--accent-2) 55%, transparent);
		background: color-mix(in srgb, var(--accent) 14%, var(--surface-strong));
	}

	.actions {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		flex-shrink: 0;
		justify-self: end;
		min-width: 0;
	}

	.header-status {
		margin: 0;
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.45rem 0.8rem;
		border: 1px solid color-mix(in srgb, var(--border-strong) 60%, transparent);
		border-radius: 1rem;
		background: color-mix(in srgb, var(--surface-strong) 74%, transparent);
		color: var(--text-muted);
		font-size: 0.68rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		box-shadow: inset 0 1px 0 color-mix(in srgb, var(--surface-strong) 44%, transparent);
	}

	.header-status-copy {
		display: grid;
		gap: 0.1rem;
	}

	.header-status-dot {
		width: 0.55rem;
		height: 0.55rem;
		border-radius: 999px;
		background: var(--accent-2);
		box-shadow: 0 0 0 0.32rem color-mix(in srgb, var(--accent-2) 14%, transparent);
	}

	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border-width: 0;
	}

	.nav-toggle {
		display: none;
		grid-template-columns: auto 1fr;
		align-items: center;
		justify-content: center;
		gap: 0.55rem;
		min-width: 5.4rem;
		height: 2.75rem;
		padding: 0.65rem 0.8rem;
		border: 1px solid color-mix(in srgb, var(--border-strong) 65%, transparent);
		border-radius: 1rem;
		background: color-mix(in srgb, var(--surface-strong) 78%, transparent);
		color: var(--text-main);
		cursor: pointer;
		transition:
			border-color 0.2s ease,
			background-color 0.2s ease,
			color 0.2s ease,
			transform 0.2s ease,
			box-shadow 0.2s ease;
	}

	.nav-toggle:hover {
		border-color: var(--accent);
		color: var(--accent);
		box-shadow: 0 14px 28px color-mix(in srgb, var(--shadow-color) 28%, transparent);
	}

	.nav-toggle:focus-visible,
	.nav-link:focus-visible,
	.mobile-nav-link:focus-visible,
	.logo:focus-visible {
		outline: 2px solid var(--accent);
		outline-offset: 3px;
	}

	.nav-toggle-line {
		display: block;
		width: 100%;
		height: 1px;
		background: currentColor;
	}

	.nav-toggle-label {
		font-size: 0.68rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	.mobile-nav-shell {
		margin-top: 1rem;
		padding-top: 1rem;
		border-top: 1px solid color-mix(in srgb, var(--border-strong) 68%, transparent);
	}

	.mobile-nav-panel {
		display: grid;
		gap: 0.75rem;
	}

	.mobile-nav-link {
		display: grid;
		grid-template-columns: auto 1fr;
		align-items: center;
		gap: 0.75rem;
		padding: 0.85rem 1rem;
		border: 1px solid color-mix(in srgb, var(--border-strong) 60%, transparent);
		border-radius: 1rem;
		background: color-mix(in srgb, var(--surface-strong) 78%, transparent);
		color: var(--text-muted);
		text-decoration: none;
		text-transform: uppercase;
		font-size: 0.82rem;
		letter-spacing: 0.08em;
	}

	.mobile-nav-link-index {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 1.6rem;
		height: 1.6rem;
		border-radius: 999px;
		border: 1px solid color-mix(in srgb, var(--border-strong) 52%, transparent);
		color: var(--accent-2);
		font-size: 0.68rem;
	}

	.mobile-nav-link.active {
		color: var(--accent);
		border-color: var(--accent);
		box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--accent-2) 20%, transparent);
	}

	@media (max-width: 640px) {
		.terminal-header {
			gap: 1rem;
			align-items: stretch;
		}

		.terminal-header-top {
			display: grid;
			grid-template-columns: minmax(0, 1fr) auto;
			align-items: start;
			gap: 0.65rem;
			width: 100%;
		}

		.brand {
			display: grid;
			gap: 0.2rem;
			min-width: 0;
		}

		.brand-kicker {
			font-size: 0.64rem;
			letter-spacing: 0.12em;
		}

		.brand-meta {
			font-size: 0.62rem;
			letter-spacing: 0.1em;
		}

		.logo {
			font-size: 1rem;
		}

		.actions {
			justify-content: flex-end;
			align-self: start;
			gap: 0.45rem;
		}

		.header-status {
			display: none;
		}

		.nav-toggle {
			min-width: 4.65rem;
			padding-inline: 0.7rem;
		}

		.terminal-header[data-mobile-nav-ready='true'] .nav-links-desktop {
			display: none;
		}

		.terminal-header[data-mobile-nav-ready='true'] .nav-toggle {
			display: inline-flex;
		}
	}

	@media (max-width: 360px) {
		.brand-meta {
			display: none;
		}

		.nav-toggle {
			min-width: 4.2rem;
			padding-inline: 0.62rem;
		}

		.nav-toggle-label {
			font-size: 0.62rem;
		}
	}

	@media (min-width: 641px) {
		.mobile-nav-shell {
			display: none !important;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.nav-toggle {
			transition: none;
		}
	}
</style>

<script>
	const mobileNavState = {
		controller: null as AbortController | null,
	};

	const initMobileNav = () => {
		mobileNavState.controller?.abort();
		mobileNavState.controller = new AbortController();

		const signal = mobileNavState.controller.signal;
		const header = document.querySelector('.terminal-header');
		const toggle = document.querySelector('[data-mobile-nav-toggle]');
		const panel = document.querySelector('[data-mobile-nav]');
		const desktopMedia = window.matchMedia('(min-width: 641px)');

		if (!(header instanceof HTMLElement)) {
			return;
		}

		if (!(toggle instanceof HTMLButtonElement) || !(panel instanceof HTMLElement)) {
			return;
		}

		header.setAttribute('data-mobile-nav-ready', 'true');

		const closeMenu = () => {
			const activeElement = document.activeElement;
			const shouldRestoreFocus = activeElement instanceof Node && panel.contains(activeElement);

			panel.hidden = true;

			if (shouldRestoreFocus) {
				toggle.focus();
			}

			toggle.setAttribute('aria-expanded', 'false');
			toggle.setAttribute('aria-label', 'Open navigation menu');
			document.body.removeAttribute('data-mobile-nav-open');
		};

		const openMenu = () => {
			panel.hidden = false;
			toggle.setAttribute('aria-expanded', 'true');
			toggle.setAttribute('aria-label', 'Close navigation menu');
			document.body.setAttribute('data-mobile-nav-open', 'true');
		};

		const handlePanelNavigation = (event: Event) => {
			const target = event.target;

			if (!(target instanceof Element)) {
				return;
			}

			if (target.closest('a[href]')) {
				closeMenu();
			}
		};

		const syncViewport = () => {
			if (desktopMedia.matches) {
				closeMenu();
			}
		};

		closeMenu();

		toggle.addEventListener(
			'click',
			() => {
				if (toggle.getAttribute('aria-expanded') === 'true') {
					closeMenu();
					return;
				}

				openMenu();
			},
			{ signal },
		);

		panel.addEventListener('click', handlePanelNavigation, { signal });

		document.addEventListener(
			'keydown',
			(event) => {
				if (event.key === 'Escape') {
					closeMenu();
				}
			},
			{ signal },
		);

		document.addEventListener(
			'click',
			(event) => {
				const target = event.target;

				if (target instanceof Node && !header.contains(target)) {
					closeMenu();
				}
			},
			{ signal },
		);

		desktopMedia.addEventListener('change', syncViewport, { signal });
	};

	initMobileNav();
	document.addEventListener('astro:page-load', initMobileNav);
</script>
