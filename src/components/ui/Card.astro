---
interface Props {
	title: string;
	description: string;
	href: string;
	motionClass?: string;
	linkText?: string;
	ariaLabel?: string;
}

const {
	title,
	description,
	href,
	motionClass = '',
	linkText = 'Read more →',
	ariaLabel = `Open: ${title}`,
} = Astro.props;
---

<div class={`editorial-card motion-enter motion-hover-lift ${motionClass}`}>
	<div class="card-content">
		<h3>{title}</h3>
		<p>{description}</p>
	</div>
	<a href={href} class="card-link mono" aria-label={ariaLabel}>
		{linkText}
	</a>
</div>

<style>
	.editorial-card {
		display: grid;
		gap: 1.15rem;
		align-content: start;
		min-height: 100%;
		border: 1px solid var(--border);
		border-radius: var(--radius-lg);
		background: var(--surface);
		padding: 1.35rem;
		margin-bottom: 0;
		box-shadow: var(--panel-shadow-soft);
	}

	.editorial-card:hover {
		border-color: var(--border-strong);
		box-shadow: 0 4px 8px var(--shadow-color), 0 12px 28px var(--shadow-color);
	}

	.card-content {
		display: grid;
		gap: 0.75rem;
	}

	h3 {
		margin: 0;
		color: var(--text-main);
		font-size: 1.35rem;
		line-height: 1.2;
	}

	p {
		margin: 0;
		color: var(--text-muted);
		font-size: 1rem;
		line-height: 1.7;
	}

	.card-link {
		display: inline-flex;
		align-items: center;
		justify-content: flex-start;
		min-height: 1.5rem;
		width: fit-content;
		padding: 0;
		border: 0;
		background: transparent;
		color: var(--accent);
		text-decoration: none;
		font-size: 0.8rem;
		font-weight: 600;
		letter-spacing: 0.04em;
		transition:
			color 0.2s ease,
			text-underline-offset 0.2s ease;
	}

	.card-link:hover,
	.card-link:focus-visible {
		color: color-mix(in srgb, var(--accent) 88%, var(--accent-2));
		text-decoration: underline;
	}
</style>
