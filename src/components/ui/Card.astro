---
interface Props {
	title: string;
	description: string;
	href: string;
	motionClass?: string;
}

const { title, description, href, motionClass = '' } = Astro.props;
---

<div class={`brutalist-card motion-enter motion-hover-lift ${motionClass}`}>
	<div class="card-content">
		<h3 class="mono">{title}</h3>
		<p>{description}</p>
	</div>
	<a href={href} class="card-link mono" aria-label={`Read post: ${title}`}>
		run ./read_post.sh &rarr;
	</a>
</div>

<style>
	.brutalist-card {
		border: 1px solid var(--border);
		background: var(--surface);
		padding: 1.5rem;
		margin-bottom: 1.5rem;
		position: relative;
	}

	.brutalist-card:hover {
		border-color: var(--accent);
		box-shadow: 4px 4px 0 var(--accent);
	}

	h3 {
		margin: 0 0 0.5rem 0;
		color: var(--text-main);
		font-size: 1.25rem;
	}

	p {
		margin: 0;
		color: var(--text-muted);
		font-size: 0.95rem;
	}

	.card-link {
		display: inline-block;
		margin-top: 1.25rem;
		color: var(--accent);
		text-decoration: none;
		font-size: 0.9rem;
		font-weight: 600;
	}

	.card-link:hover {
		text-decoration: underline;
	}
</style>
