---
interface Props {
	title: string;
	description: string;
	href: string;
	motionClass?: string;
	linkText?: string;
	ariaLabel?: string;
}

const {
	title,
	description,
	href,
	motionClass = '',
	linkText = 'run ./read_post.sh →',
	ariaLabel = `Open: ${title}`,
} = Astro.props;
---

<div class={`brutalist-card motion-enter motion-hover-lift ${motionClass}`}>
	<div class="card-content">
		<h3 class="mono">{title}</h3>
		<p>{description}</p>
	</div>
	<a href={href} class="card-link mono" aria-label={ariaLabel}>
		{linkText}
	</a>
</div>

<style>
	.brutalist-card {
		display: grid;
		gap: 1.15rem;
		align-content: start;
		min-height: 100%;
		border: 1px solid color-mix(in srgb, var(--border-strong) 72%, transparent);
		background:
			linear-gradient(180deg, color-mix(in srgb, var(--surface-strong) 92%, transparent) 0%, color-mix(in srgb, var(--surface-soft) 92%, transparent) 100%);
		padding: 1.35rem;
		margin-bottom: 0;
		position: relative;
		overflow: clip;
		box-shadow: inset 0 1px 0 color-mix(in srgb, var(--surface-strong) 44%, transparent);
	}

	.brutalist-card::before {
		content: '';
		position: absolute;
		inset: 0;
		pointer-events: none;
		background:
			linear-gradient(var(--grid-line) 1px, transparent 1px),
			linear-gradient(90deg, var(--grid-line) 1px, transparent 1px);
		background-size: 3rem 3rem;
		opacity: 0.35;
		mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.6), transparent 84%);
	}

	.brutalist-card:hover {
		border-color: var(--accent);
		box-shadow:
			0 0 0 1px var(--accent),
			0 18px 36px color-mix(in srgb, var(--shadow-color) 22%, transparent);
	}

	.brutalist-card::after {
		content: '';
		position: absolute;
		inset: 0 0 auto 0;
		height: 2px;
		background: linear-gradient(90deg, transparent, var(--accent), var(--accent-2), transparent);
		opacity: 0;
		transition: opacity 0.3s ease;
		z-index: 2;
	}

	.brutalist-card:hover::after {
		opacity: 0.7;
	}

	.brutalist-card > * {
		position: relative;
		z-index: 1;
	}

	.card-content {
		display: grid;
		gap: 0.75rem;
	}

	h3 {
		margin: 0;
		color: var(--text-main);
		font-size: 1.35rem;
		line-height: 1.2;
	}

	p {
		margin: 0;
		color: var(--text-muted);
		font-size: 1rem;
		line-height: 1.7;
	}

	.card-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 2.5rem;
		width: fit-content;
		padding: 0.45rem 0.8rem;
		border: 1px solid color-mix(in srgb, var(--border-strong) 70%, transparent);
		background: color-mix(in srgb, var(--surface) 58%, transparent);
		color: var(--accent);
		text-decoration: none;
		font-size: 0.9rem;
		font-weight: 600;
		letter-spacing: 0.08em;
		font-variant: small-caps;
		transition:
			border-color 0.2s ease,
			background-color 0.2s ease,
			text-underline-offset 0.2s ease;
	}

	.card-link:hover,
	.card-link:focus-visible {
		border-color: var(--accent);
		background: color-mix(in srgb, var(--accent) 12%, var(--surface-strong));
		text-decoration: none;
	}
</style>
