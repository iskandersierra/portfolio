---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import SEO from '../components/SEO.astro';
import Footer from '../components/layout/Footer.astro';
import Header from '../components/layout/Header.astro';
import { resolveSeoMetadata, type SeoInput } from '../utils/seo';

export interface Props extends SeoInput {
	seo?: SeoInput;
}

const { seo, title, description, canonicalUrl, pageType, socialImage, socialImageAlt } = Astro.props;

const metadata = resolveSeoMetadata(
	{
		title: seo?.title ?? title,
		description: seo?.description ?? description,
		canonicalUrl: seo?.canonicalUrl ?? canonicalUrl,
		pageType: seo?.pageType ?? pageType,
		socialImage: seo?.socialImage ?? socialImage,
		socialImageAlt: seo?.socialImageAlt ?? socialImageAlt,
	},
	Astro.url,
	Astro.site,
);
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<ClientRouter />
		<SEO {...metadata} />

		<script is:inline>
			(function () {
				const storageKey = 'theme';
				const root = document.documentElement;
				const lifecycleState = window.__portfolioThemeLifecycle ?? {
					mediaQuery: window.matchMedia('(prefers-color-scheme: dark)'),
					controller: null,
				};
				const mediaQuery = lifecycleState.mediaQuery;

				lifecycleState.controller?.abort();
				lifecycleState.controller = new AbortController();
				window.__portfolioThemeLifecycle = lifecycleState;

				const { signal } = lifecycleState.controller;

				const getStoredPreference = () => {
					try {
						return localStorage.getItem(storageKey);
					} catch {
						return null;
					}
				};

				const resolveTheme = (preference) => {
					if (preference === 'light' || preference === 'dark') {
						return preference;
					}

					return mediaQuery.matches ? 'dark' : 'light';
				};

				const notifyThemeChange = (mode, resolvedTheme) => {
					window.dispatchEvent(
						new CustomEvent('portfolio:theme-change', {
							detail: { mode, resolvedTheme },
						}),
					);
				};

				const applyTheme = (preference) => {
					const resolvedTheme = resolveTheme(preference);
					const mode = preference === 'light' || preference === 'dark' ? preference : 'system';

					root.setAttribute('data-theme', resolvedTheme);
					root.setAttribute('data-theme-mode', mode);
					root.style.colorScheme = resolvedTheme;

					notifyThemeChange(mode, resolvedTheme);
				};

				const syncStoredTheme = () => {
					applyTheme(getStoredPreference());
				};

				window.__portfolioTheme = {
					getPreference: getStoredPreference,
					getResolvedTheme: () => (root.getAttribute('data-theme') === 'dark' ? 'dark' : 'light'),
					getMode: () => root.getAttribute('data-theme-mode') ?? 'system',
					setPreference: (preference) => {
						try {
							if (preference === 'light' || preference === 'dark') {
								localStorage.setItem(storageKey, preference);
							} else {
								localStorage.removeItem(storageKey);
							}
						} catch {
							// Ignore localStorage access issues and keep the in-memory theme state.
						}

						applyTheme(preference);
					},
				};

				syncStoredTheme();
				root.setAttribute('data-theme-ready', 'true');

				const handleSystemThemeChange = () => {
					if (!getStoredPreference()) {
						applyTheme(null);
					}
				};

				const handleStorageChange = (event) => {
					if (event.key === storageKey) {
						applyTheme(event.newValue);
					}
				};

				mediaQuery.addEventListener('change', handleSystemThemeChange, { signal });
				window.addEventListener('storage', handleStorageChange, { signal });
				document.addEventListener('astro:page-load', syncStoredTheme, { signal });
			})();
		</script>
	</head>
	<body>
		<div class="grain-overlay" aria-hidden="true"></div>
		<div class="signal-stage">
			<div class="signal-stage__field" aria-hidden="true">
				<span class="signal-orbit signal-orbit-a"></span>
				<span class="signal-orbit signal-orbit-b"></span>
				<span class="signal-wire signal-wire-a"></span>
				<span class="signal-wire signal-wire-b"></span>
				<span class="signal-wire signal-wire-c"></span>
				<span class="signal-node signal-node-a"></span>
				<span class="signal-node signal-node-b"></span>
				<span class="signal-node signal-node-c"></span>
				<span class="signal-node signal-node-d"></span>
			</div>
			<div class="signal-stage__frame">
				<div class="signal-stage__rail signal-stage__rail--top mono" aria-hidden="true">
					<span>signal graph studio</span>
					<span>signal frame / route network</span>
				</div>
				<div class="terminal-window">
					<Header />
					<slot />
					<Footer />
				</div>
				<div class="signal-stage__rail signal-stage__rail--bottom mono" aria-hidden="true">
					<span>adaptive theme control layer</span>
					<span>content graph online</span>
				</div>
			</div>
		</div>
	</body>
</html>
