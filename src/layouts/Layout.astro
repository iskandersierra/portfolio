---
import '../styles/global.css';
import SEO from '../components/SEO.astro';
import { resolveSeoMetadata, type SeoInput } from '../utils/seo';

export interface Props extends SeoInput {
	seo?: SeoInput;
}

const { seo, title, description, canonicalUrl, pageType, socialImage, socialImageAlt } = Astro.props;

const metadata = resolveSeoMetadata(
	{
		title: seo?.title ?? title,
		description: seo?.description ?? description,
		canonicalUrl: seo?.canonicalUrl ?? canonicalUrl,
		pageType: seo?.pageType ?? pageType,
		socialImage: seo?.socialImage ?? socialImage,
		socialImageAlt: seo?.socialImageAlt ?? socialImageAlt,
	},
	Astro.url,
	Astro.site,
);
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<SEO {...metadata} />

		<script is:inline>
			(function () {
				const getTheme = () => {
					if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
						return localStorage.getItem('theme');
					}
					if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
						return 'dark';
					}
					return 'light';
				};
				const theme = getTheme();
				if (theme === 'dark') {
					document.documentElement.setAttribute('data-theme', 'dark');
				} else {
					document.documentElement.removeAttribute('data-theme');
				}
			})();
		</script>
	</head>
	<body>
		<div class="grain-overlay"></div>
		<slot />
	</body>
</html>
