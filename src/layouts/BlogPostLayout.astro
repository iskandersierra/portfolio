---
import AuthorBlock from '../components/blog/AuthorBlock.astro';
import Layout from './Layout.astro';
import {
	formatContentDate,
	getBlogPostHref,
	getBlogTagHref,
	type BlogEntry,
} from '../utils/content';

export interface Props {
	post: BlogEntry;
	adjacentPosts?: {
		previous?: BlogEntry;
		next?: BlogEntry;
	};
}

const { post, adjacentPosts = {} } = Astro.props as Props;
const formattedDate = formatContentDate(post.data.date);
const readTimeLabel = `${post.data.readTime} min read`;
---

<Layout
	seo={{
		title: post.data.title,
		description: post.data.excerpt,
		pageType: 'article',
		socialImage: post.data.coverImage,
	}}
>
	<main class="container page-shell detail-surface detail-surface--blog">
		<article class="blog-post-article blog-post-layout post-shell detail-shell">
			<header class="detail-hero detail-hero--blog motion-enter motion-delay-1">
				<div class="blog-post-header post-header detail-module detail-module--hero">
					<p class="blog-post-kicker mono">Article signal</p>
					<h1 class="post-title">{post.data.title}</h1>
					<p class="blog-post-excerpt">{post.data.excerpt}</p>
					<div class="blog-post-meta post-meta mono" aria-label="Post metadata">
						<span>Published {formattedDate}</span>
						<span>Reading time {readTimeLabel}</span>
						<span>Field note</span>
					</div>
					<ul class="blog-post-tags post-tag-list" aria-label="Post tags">
						{post.data.tags.map((tag) => (
							<li>
								<a href={getBlogTagHref(tag)}>{tag}</a>
							</li>
						))}
					</ul>
				</div>

				<aside class="detail-hero__graph detail-module" aria-labelledby="blog-detail-map-title">
					<div class="detail-module__header">
						<p class="mono detail-module__eyebrow" id="blog-detail-map-title">Reading map</p>
						<p class="mono detail-module__status">Knowledge node</p>
					</div>
					<div class="detail-hero__field detail-hero__field--blog" aria-hidden="true">
						<span class="detail-orbit detail-orbit--a"></span>
						<span class="detail-orbit detail-orbit--b"></span>
						<span class="detail-wire detail-wire--a"></span>
						<span class="detail-wire detail-wire--b"></span>
						<span class="detail-wire detail-wire--c"></span>
						<span class="detail-node detail-node--a"><span>archive</span></span>
						<span class="detail-node detail-node--b"><span>article</span></span>
						<span class="detail-node detail-node--c"><span>author</span></span>
						<span class="detail-node detail-node--d"><span>tags</span></span>
					</div>
					<dl class="detail-hero__metrics" aria-label="Blog article overview">
						<div>
							<dt class="mono">Published</dt>
							<dd>{formattedDate}</dd>
						</div>
						<div>
							<dt class="mono">Topics</dt>
							<dd>{post.data.tags.length}</dd>
						</div>
						<div>
							<dt class="mono">Format</dt>
							<dd>Long-form article</dd>
						</div>
					</dl>
				</aside>
			</header>

			<div class="detail-grid detail-grid--blog">
				<div class="detail-main">
					<section class="detail-module detail-module--body motion-enter motion-delay-2">
						<div class="detail-module__header">
							<p class="mono detail-module__eyebrow">Article</p>
							<p class="mono detail-module__status">Reading view</p>
						</div>
						<div class="blog-post-body post-body">
							<slot />
						</div>
					</section>
				</div>

				<aside class="detail-sidebar">
					<section class="detail-module detail-module--context motion-enter motion-delay-2" aria-labelledby="blog-context-title">
						<div class="detail-module__header">
							<p class="mono detail-module__eyebrow" id="blog-context-title">At a glance</p>
							<p class="mono detail-module__status">Article context</p>
						</div>
						<p class="detail-context-copy">
							This article stays easy to scan by keeping the publication details, topics, and nearby reading
							paths visible without crowding the main text.
						</p>
						<dl class="detail-fact-list" aria-label="Blog article facts">
							<div>
								<dt class="mono">Published</dt>
								<dd>{formattedDate}</dd>
							</div>
							<div>
								<dt class="mono">Reading time</dt>
								<dd>{readTimeLabel}</dd>
							</div>
							<div>
								<dt class="mono">Topics</dt>
								<dd>{post.data.tags.join(' / ')}</dd>
							</div>
						</dl>
						<nav class="detail-route-nav" aria-label="Adjacent blog posts">
							{adjacentPosts.next ? (
								<a class="detail-route-link" href={getBlogPostHref(adjacentPosts.next.id)}>
									<span class="mono detail-route-link__label">Newer article</span>
									<strong>{adjacentPosts.next.data.title}</strong>
								</a>
							) : null}
							{adjacentPosts.previous ? (
								<a class="detail-route-link" href={getBlogPostHref(adjacentPosts.previous.id)}>
									<span class="mono detail-route-link__label">Earlier article</span>
									<strong>{adjacentPosts.previous.data.title}</strong>
								</a>
							) : null}
							{!adjacentPosts.next && !adjacentPosts.previous ? (
								<a class="detail-route-link detail-route-link--solo" href="/blog">
									<span class="mono detail-route-link__label">Article index</span>
									<strong>Browse all articles</strong>
								</a>
							) : null}
						</nav>
					</section>

					<div class="blog-post-footer detail-module detail-module--author motion-enter motion-delay-3">
						<div class="detail-module__header">
							<p class="mono detail-module__eyebrow">About the author</p>
							<p class="mono detail-module__status">Profile</p>
						</div>
						<AuthorBlock />
					</div>
				</aside>
			</div>
		</article>
	</main>
</Layout>

<style>
	.detail-surface {
		padding-block: 2rem 4rem;
	}

	.detail-shell {
		max-width: none;
		padding-block: 0;
		gap: 1.25rem;
	}

	.detail-hero,
	.detail-grid {
		display: grid;
		gap: 1.25rem;
	}

	.detail-hero {
		grid-template-columns: minmax(0, 1.2fr) minmax(18rem, 0.92fr);
	}

	.detail-grid--blog {
		grid-template-columns: minmax(0, 1.2fr) minmax(17rem, 0.8fr);
		align-items: start;
	}

	.detail-main,
	.detail-sidebar,
	.detail-hero__graph,
	.detail-module,
	.detail-hero__field,
	.blog-post-body {
		min-width: 0;
	}

	.detail-sidebar {
		display: grid;
		gap: 1.25rem;
	}

	.detail-module {
		position: relative;
		border: 1px solid color-mix(in srgb, var(--border-strong) 72%, transparent);
		background:
			linear-gradient(180deg, color-mix(in srgb, var(--surface-strong) 92%, transparent) 0%, color-mix(in srgb, var(--surface) 94%, transparent) 100%);
		box-shadow: var(--panel-shadow-soft);
		padding: clamp(1.1rem, 2.7vw, 1.65rem);
		overflow: clip;
	}

	.detail-module::before {
		content: '';
		position: absolute;
		inset: 0;
		pointer-events: none;
		background:
			linear-gradient(var(--grid-line) 1px, transparent 1px),
			linear-gradient(90deg, var(--grid-line) 1px, transparent 1px);
		background-size: 3rem 3rem;
		opacity: 0.42;
		mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.6), transparent 86%);
	}

	.detail-module > * {
		position: relative;
		z-index: 1;
	}

	.detail-module__header {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		gap: 0.75rem;
		flex-wrap: wrap;
		margin-bottom: 1rem;
	}

	.detail-module__eyebrow,
	.detail-module__status,
	.detail-hero__metrics dt,
	.detail-fact-list dt,
	.detail-route-link__label {
		margin: 0;
		font-size: 0.72rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	.detail-module__eyebrow,
		.blog-post-kicker,
		.detail-route-link__label {
		color: var(--accent-2);
	}

	.detail-module__status,
	.detail-hero__metrics dt,
	.detail-fact-list dt {
		color: var(--text-soft);
	}

	.detail-hero__field {
		position: relative;
		min-height: 16rem;
		border: 1px solid color-mix(in srgb, var(--border-strong) 60%, transparent);
		background:
			radial-gradient(circle at 18% 18%, color-mix(in srgb, var(--accent) 15%, transparent) 0, transparent 26%),
			radial-gradient(circle at 78% 18%, color-mix(in srgb, var(--accent-2) 12%, transparent) 0, transparent 22%),
			color-mix(in srgb, var(--surface-soft) 78%, transparent);
		overflow: hidden;
	}

	.detail-orbit,
	.detail-wire,
	.detail-node {
		position: absolute;
		display: block;
	}

	.detail-orbit {
		border: 1px solid color-mix(in srgb, var(--border-strong) 52%, transparent);
		border-radius: 999px;
		opacity: 0.36;
	}

	.detail-orbit--a {
		left: 1rem;
		top: 1rem;
		width: 8rem;
		height: 8rem;
	}

	.detail-orbit--b {
		right: 0.9rem;
		bottom: 1.1rem;
		width: 6.5rem;
		height: 6.5rem;
	}

	.detail-wire {
		height: 1px;
		background: linear-gradient(90deg, transparent, var(--line-strong), transparent);
	}

	.detail-wire--a {
		top: 28%;
		left: 20%;
		width: 42%;
		transform: rotate(16deg);
	}

	.detail-wire--b {
		top: 53%;
		left: 38%;
		width: 30%;
		transform: rotate(-10deg);
	}

	.detail-wire--c {
		bottom: 24%;
		left: 18%;
		width: 52%;
		transform: rotate(5deg);
	}

	.detail-node {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.38rem 0.65rem;
		border: 1px solid color-mix(in srgb, var(--border-strong) 60%, transparent);
		border-radius: 999px;
		background: color-mix(in srgb, var(--surface-strong) 82%, transparent);
		box-shadow: 0 12px 24px color-mix(in srgb, var(--shadow-color) 20%, transparent);
		font-family: 'Azeret Mono', monospace;
		font-size: 0.68rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--text-main);
	}

	.detail-node--a {
		left: 1.15rem;
		top: 2rem;
	}

	.detail-node--b {
		left: 43%;
		top: 42%;
	}

	.detail-node--c {
		right: 1rem;
		top: 1.9rem;
	}

	.detail-node--d {
		left: 2rem;
		bottom: 1.4rem;
	}

	.detail-hero__metrics,
	.detail-fact-list {
		display: grid;
		gap: 0.75rem;
		margin: 0;
	}

	.detail-hero__metrics {
		grid-template-columns: repeat(3, minmax(0, 1fr));
		margin-top: 1rem;
	}

	.detail-hero__metrics div,
	.detail-fact-list div {
		padding: 0.85rem 0.95rem;
		border: 1px solid var(--border);
		background: color-mix(in srgb, var(--surface-soft) 82%, transparent);
	}

	.detail-hero__metrics dd,
	.detail-fact-list dd {
		margin: 0.35rem 0 0;
		color: var(--text-main);
		font-weight: 600;
	}

	.blog-post-kicker {
		margin: 0;
	}

	.blog-post-excerpt,
	.detail-context-copy {
		margin: 0;
		max-width: 65ch;
		color: var(--text-muted);
		font-size: 1.02rem;
		line-height: 1.72;
	}

	.blog-post-body {
		max-width: 68ch;
	}

	.detail-route-nav {
		display: grid;
		gap: 0.75rem;
		margin-top: 1rem;
	}

	.detail-route-link {
		display: grid;
		gap: 0.3rem;
		padding: 0.9rem 1rem;
		border: 1px solid color-mix(in srgb, var(--border-strong) 68%, transparent);
		background: color-mix(in srgb, var(--surface-soft) 82%, transparent);
		color: var(--text-main);
		text-decoration: none;
	}

	.detail-route-link:hover,
	.detail-route-link:focus-visible {
		border-color: var(--accent);
		background: color-mix(in srgb, var(--accent) 10%, var(--surface-strong));
		text-decoration: none;
	}

	.detail-route-link strong {
		margin: 0;
		font-size: 1rem;
		line-height: 1.4;
	}

	@media (max-width: 960px) {
		.detail-hero,
		.detail-grid--blog {
			grid-template-columns: 1fr;
		}

		.detail-sidebar {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 720px) {
		.detail-hero__metrics {
			grid-template-columns: 1fr;
		}

		.detail-sidebar {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 640px) {
		.detail-surface {
			padding-block: 1.5rem 3rem;
		}

		.detail-shell {
			gap: 1rem;
		}

		.detail-module {
			padding: 1rem;
		}

		.detail-hero__field {
			min-height: 13rem;
		}

		.detail-node {
			font-size: 0.62rem;
			letter-spacing: 0.05em;
		}

		.detail-node--b {
			left: 35%;
		}
	}
</style>
