# EditorConfig helps maintain consistent coding styles.
# https://editorconfig.org/

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{astro,mjs,js,jsx,ts,tsx,css}]
indent_style = tab

[*.json]
indent_style = space
indent_size = 2

[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

[*.{yaml,yml}]
indent_style = space
indent_size = 2
