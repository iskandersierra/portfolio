{
  "name": "astro-dir",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "clean": "node -e \"const fs = require('node:fs'); for (const target of ['dist', '.astro', 'node_modules/.astro']) { fs.rmSync(target, { recursive: true, force: true }); }\"",
    "dev": "astro dev",
    "build": "pnpm clean && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "test": "pnpm test:e2e",
    "test:e2e": "playwright test",
    "test:seo": "pnpm test:e2e -- tests/e2e/seo.spec.ts",
    "check:md": "markdownlint-cli2",
    "check:styles": "stylelint \"src/**/*.{css,astro}\"",
    "check:ts": "astro check",
    "check:lint": "eslint .",
    "check:format": "prettier --check .",
    "fix:md": "markdownlint-cli2 --fix",
    "fix:styles": "stylelint --fix \"src/**/*.{css,astro}\"",
    "fix:lint": "eslint --fix .",
    "fix:format": "prettier --write .",
    "check": "pnpm check:md && pnpm check:styles && pnpm check:ts && pnpm check:lint && pnpm check:format",
    "fix": "pnpm fix:md && pnpm fix:styles && pnpm check:ts && pnpm fix:lint && pnpm fix:format"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.7",
    "@astrojs/netlify": "^7.0.2",
    "@fontsource/azeret-mono": "^5.2.11",
    "@fontsource/exo-2": "^5.2.8",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/syne": "^5.2.7",
    "astro": "^6.0.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^10.0.3",
    "eslint-plugin-astro": "^1.6.0",
    "globals": "^17.4.0",
    "markdownlint-cli2": "^0.21.0",
    "postcss-html": "^1.8.1",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "sharp": "^0.34.5",
    "stylelint": "^16.26.0",
    "typescript": "^5.9.3"
  }
}
